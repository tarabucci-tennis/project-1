<% content_for :title, "Players · Court Report" %>

<div class="cr-admin-page">
  <div class="cr-page-header">
    <h1 class="cr-page-title">Players</h1>
    <%= link_to "+ Add Player", new_user_path, class: "cr-btn" %>
  </div>

  <table class="cr-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td>
            <% if user.email.present? %>
              <%= user.email %>
            <% else %>
              <span style="color: #9ca3af; font-style: italic;">no email yet</span>
            <% end %>
          </td>
          <td>
            <span class="cr-badge <%= user.admin? ? 'cr-badge-admin' : 'cr-badge-player' %>">
              <%= user.admin? ? "Admin" : "Player" %>
            </span>
          </td>
          <td>
            <%= link_to "Edit", edit_user_path(user), class: "cr-btn cr-btn-secondary cr-btn-sm" %>
            <% unless user == current_user %>
              <%= button_to "Remove", user_path(user), method: :delete, data: { turbo_confirm: "Remove #{user.name}?" }, class: "cr-btn cr-btn-sm", form: { style: "display:inline" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
