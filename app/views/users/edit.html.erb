<% content_for :title, "Edit #{@user.name} · Court Report" %>

<div class="cr-login-page">
  <div class="cr-login-card">
    <h1>Edit <%= @user.name %></h1>

    <%= form_with model: @user do |f| %>
      <% if @user.errors.any? %>
        <div class="cr-flash cr-flash-alert" style="margin-bottom: 16px;">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="cr-field">
        <%= f.label :name %>
        <%= f.text_field :name %>
      </div>
      <div class="cr-field">
        <%= f.label :email, "Email (used to sign in)" %>
        <%= f.email_field :email, placeholder: "email@example.com" %>
      </div>
      <div class="cr-field">
        <label>
          <%= f.check_box :admin %>
          Admin privileges
        </label>
      </div>
      <div class="cr-field">
        <%= f.label :tennislink_person_id, "TennisLink PersonID" %>
        <%= f.text_field :tennislink_person_id, placeholder: "e.g. 12345678" %>
        <div style="font-size: 12px; color: #666; margin-top: 4px;">
          From the <code>PersonID=</code> query param on the user's TennisLink profile URL.
          Used by <%= link_to "admin TennisLink test", admin_tennislink_test_path(person_id: @user.tennislink_person_id, year: Date.current.year) %>.
        </div>
      </div>
      <%= f.submit "Save Changes" %>
      <div style="margin-top: 12px;">
        <%= link_to "Cancel", users_path, class: "cr-btn cr-btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
