<% content_for :title, "Add Player · Court Report" %>

<div class="cr-login-page">
  <div class="cr-login-card">
    <h1>Add Player</h1>

    <%= form_with model: @user do |f| %>
      <% if @user.errors.any? %>
        <div class="cr-flash cr-flash-alert" style="margin-bottom: 16px;">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="cr-field">
        <%= f.label :name %>
        <%= f.text_field :name, autofocus: true %>
      </div>
      <div class="cr-field">
        <%= f.label :email %>
        <%= f.email_field :email %>
      </div>
      <div class="cr-field">
        <label>
          <%= f.check_box :admin %>
          Admin privileges
        </label>
      </div>
      <%= f.submit "Add Player" %>
      <div style="margin-top: 12px;">
        <%= link_to "Cancel", users_path, class: "cr-btn cr-btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
