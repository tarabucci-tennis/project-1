<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#060f1e"/>
<title>Court Report</title>
<%= csrf_meta_tags %>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{--navy:#060f1e;--blue:#0a2240;--cobalt:#0e3d6e;--accent:#c9a84c;--accent2:#f0cc6e;--white:#fff;--off:#f7f9fc;--surface:#fff;--green:#16a34a;--red:#dc2626;--text:#0a0f1a;--sub:#64748b;--border:#e2e8f0;--pur:#3b0764;--pur2:#6d28d9;}
body{font-family:'Inter',sans-serif;background:var(--off);color:var(--text);-webkit-font-smoothing:antialiased;}
@keyframes glow{0%,100%{box-shadow:0 0 0 0 rgba(201,168,76,.4)}50%{box-shadow:0 0 0 8px rgba(201,168,76,0)}}
@keyframes bounce-ball{0%,100%{transform:translateY(0)}25%{transform:translateY(-6px) rotate(-8deg)}50%{transform:translateY(0) rotate(0)}75%{transform:translateY(-3px) rotate(8deg)}}
@keyframes fu{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.fu{animation:fu .35s cubic-bezier(.22,1,.36,1) both;}
.app-header{background:var(--navy);position:sticky;top:0;z-index:200;box-shadow:0 2px 20px rgba(0,0,0,.3);}
.header-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:16px 32px;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-mark{width:42px;height:42px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;animation:glow 3s ease infinite,bounce-ball 1.6s ease-in-out infinite;box-shadow:0 3px 14px rgba(201,168,76,.4);}
.logo-name{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:5px;color:var(--white);}
.logo-name span{color:var(--accent);}
.season-pill{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:2px;color:rgba(255,255,255,.35);border:1px solid rgba(255,255,255,.1);padding:5px 14px;border-radius:20px;}
.search-btn{width:38px;height:38px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;color:rgba(255,255,255,.6);}
.team-tabs-wrap{background:var(--navy);border-bottom:1px solid rgba(255,255,255,.06);}
.team-tabs{max-width:1200px;margin:0 auto;display:flex;padding:0 32px;flex-wrap:nowrap;}
.team-tab{padding:12px 28px;border:none;background:none;color:rgba(255,255,255,.35);font-family:'Inter',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;border-bottom:2px solid transparent;letter-spacing:.8px;text-transform:uppercase;position:relative;white-space:nowrap;}
.team-tab:hover{color:rgba(255,255,255,.7);}
.team-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
/* League Dropdowns */
.league-dropdown{position:absolute;top:100%;left:0;min-width:220px;background:var(--navy);border:1px solid rgba(255,255,255,.1);border-radius:0 0 12px 12px;box-shadow:0 12px 32px rgba(0,0,0,.5);display:none;z-index:300;overflow:hidden;}
.team-tab:hover .league-dropdown,.team-tab.dropdown-open .league-dropdown{display:block;}
.league-dropdown a{display:block;padding:12px 20px;color:rgba(255,255,255,.6);text-decoration:none;font-size:.8rem;font-weight:500;letter-spacing:.5px;text-transform:none;transition:all .15s;border-bottom:1px solid rgba(255,255,255,.04);}
.league-dropdown a:last-child{border-bottom:none;}
.league-dropdown a:hover{background:rgba(201,168,76,.08);color:var(--white);}
.league-dropdown a.dd-active{color:var(--accent);background:rgba(201,168,76,.06);font-weight:700;}
.league-dropdown a .dd-sub{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:rgba(255,255,255,.25);display:block;margin-top:2px;}
.app-body{max-width:1200px;margin:0 auto;width:100%;padding:0 32px;}
.desktop-nav{display:flex;background:var(--surface);border-bottom:2px solid var(--border);margin-bottom:24px;border-radius:12px 12px 0 0;overflow:hidden;}
.dnav-btn{flex:1;padding:14px 10px;border:none;background:none;font-family:'Inter',sans-serif;font-size:.82rem;font-weight:600;color:var(--sub);cursor:pointer;transition:all .18s;border-bottom:3px solid transparent;display:flex;align-items:center;justify-content:center;gap:6px;}
.dnav-btn:hover{color:var(--cobalt);background:var(--off);}
.dnav-btn.active{color:var(--blue);border-bottom-color:var(--accent);}
.team-hero{padding:40px 40px 36px;color:var(--white);position:relative;overflow:hidden;border-radius:16px;margin:24px 0 0;}
.th-fri{background:linear-gradient(150deg,#060f1e,#0a2240 50%,#0e3d6e);}
.th-tue{background:linear-gradient(150deg,#0f0620,#1e0840 50%,#3b0764);}
.th-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:40px 40px;}
.th-glow{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse at 80% 40%,rgba(201,168,76,.08),transparent 65%);}
.th-content{position:relative;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:24px;}
.th-tag{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.th-tag::before{content:'';width:16px;height:1px;background:var(--accent);}
.th-name{font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:5px;line-height:1;color:var(--white);margin-bottom:6px;}
.th-sub{font-size:.84rem;color:rgba(255,255,255,.4);}
.th-stats{display:flex;gap:0;}
.th-stat{padding:0 28px 0 0;margin-right:28px;border-right:1px solid rgba(255,255,255,.1);}
.th-stat:last-child{border-right:none;margin-right:0;padding-right:0;}
.th-sv{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:2px;line-height:1;}
.th-sv.gold{color:var(--accent);}
.th-sl{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:4px;}
.quick-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:20px 0;}
.qs{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;text-align:center;position:relative;overflow:hidden;}
.qs::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.qs-val{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:1px;color:var(--text);line-height:1;}
.qs-val.gold{color:var(--accent)}
.qs-label{font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--sub);margin-top:4px;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:32px;}
.one-col{margin-bottom:32px;}
.sec-head{display:flex;align-items:center;margin-bottom:14px;}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:3px;color:var(--text);}
.sec-line{flex:1;height:1px;background:var(--border);margin-left:14px;}
.sched-list{display:flex;flex-direction:column;gap:10px;}
.sched-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:14px;transition:box-shadow .2s,transform .2s;}
.sched-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.07);transform:translateY(-1px);}
.sdate{background:var(--navy);color:var(--white);border-radius:8px;padding:8px 10px;text-align:center;flex-shrink:0;min-width:48px;}
.sd-mon{font-family:'JetBrains Mono',monospace;font-size:.52rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin-bottom:1px;}
.sd-day{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:1px;line-height:1;}
.sinfo{flex:1;}
.sopp{font-weight:700;font-size:.9rem;margin-bottom:2px;}
.smeta{font-size:.72rem;color:var(--sub);}
.loc-home{font-size:.62rem;font-weight:700;padding:2px 8px;border-radius:5px;background:#dbeafe;color:#1d4ed8;white-space:nowrap;flex-shrink:0;}
.loc-away{font-size:.62rem;font-weight:700;padding:2px 8px;border-radius:5px;background:#fee2e2;color:#b91c1c;white-space:nowrap;flex-shrink:0;}
.no-results{text-align:center;padding:40px 24px;color:var(--sub);font-size:.9rem;background:var(--surface);border:1px solid var(--border);border-radius:12px;line-height:1.8;}
.stand-table{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.stand-head{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:var(--off);}
.stand-title{font-family:'Bebas Neue',sans-serif;font-size:.88rem;letter-spacing:2px;color:var(--text);}
.stand-sub{font-family:'JetBrains Mono',monospace;font-size:.64rem;color:var(--sub);}
table{width:100%;border-collapse:collapse;}
th{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--sub);padding:9px 14px;text-align:left;background:var(--off);border-bottom:1px solid var(--border);}
td{padding:11px 14px;font-size:.85rem;border-bottom:1px solid var(--border);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:rgba(201,168,76,.03);}
.us-row td{background:rgba(201,168,76,.06);}
.rank-c{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;color:var(--sub);}
.bold-c{font-weight:700;}.mono-c{font-family:'JetBrains Mono',monospace;font-size:.78rem;}
.roster-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:14px;}
.rcard{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:22px 16px;text-align:center;cursor:pointer;transition:transform .2s,box-shadow .2s;position:relative;}
.rcard:hover{transform:translateY(-4px);box-shadow:0 12px 28px rgba(0,0,0,.1);}
.rcard.cap::after{content:'C';position:absolute;top:10px;right:10px;width:20px;height:20px;background:var(--accent);color:var(--navy);border-radius:50%;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;}
.rav{width:56px;height:56px;border-radius:50%;margin:0 auto 11px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:#fff;overflow:hidden;}
.rav img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.rav.blue{background:linear-gradient(135deg,var(--cobalt),var(--blue));box-shadow:0 4px 12px rgba(14,61,110,.28);}
.rav.you{background:linear-gradient(135deg,#8b6914,var(--accent));color:var(--navy);box-shadow:0 4px 12px rgba(201,168,76,.38);}
.rav.pur{background:linear-gradient(135deg,var(--pur),var(--pur2));box-shadow:0 4px 12px rgba(91,18,160,.28);}
.rname{font-weight:700;font-size:.88rem;margin-bottom:2px;}
.rntrp{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--sub);}
.wa-section{display:flex;flex-direction:column;align-items:center;text-align:center;padding:48px 20px;gap:16px;}
.wa-icon{font-size:3.5rem;}
.wa-title{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:4px;}
.wa-sub{font-size:.9rem;color:var(--sub);max-width:380px;line-height:1.7;}
.wa-btn{display:flex;align-items:center;gap:14px;padding:16px 24px;border-radius:12px;background:#f0fdf4;border:1px solid #86efac;text-decoration:none;color:#15803d;font-weight:700;font-size:.9rem;width:100%;max-width:360px;margin-top:8px;transition:all .2s;}
.wa-btn:hover{background:#dcfce7;}
.wa-btn-sub{font-size:.74rem;color:#4ade80;font-weight:400;margin-top:1px;}
.mobile-nav{display:none;position:fixed;bottom:0;left:0;right:0;background:linear-gradient(180deg,rgba(6,15,30,.97),var(--navy));backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid rgba(201,168,76,.15);padding:0 0 env(safe-area-inset-bottom);z-index:200;box-shadow:0 -4px 24px rgba(0,0,0,.4);}
.mobile-nav-inner{display:flex;max-width:600px;margin:0 auto;}
.bnav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;padding:12px 4px 10px;border:none;background:none;cursor:pointer;color:rgba(255,255,255,.4);transition:all .2s ease;position:relative;-webkit-tap-highlight-color:transparent;text-decoration:none;font-family:inherit;}
.bnav-btn:active{transform:scale(.92);}
.bnav-btn.active{color:var(--accent);}
.bnav-btn.active::before{content:'';position:absolute;top:0;left:25%;right:25%;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);border-radius:0 0 2px 2px;}
.bnav-icon{font-size:1.4rem;line-height:1;filter:grayscale(20%);transition:filter .2s,transform .2s;}
.bnav-btn.active .bnav-icon{filter:grayscale(0%);transform:scale(1.1);}
.bnav-label{font-family:'JetBrains Mono',monospace;font-size:.52rem;letter-spacing:1.2px;text-transform:uppercase;font-weight:600;white-space:nowrap;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;animation:fadeIn .2s ease;}
.modal{background:var(--surface);border-radius:20px;width:90%;max-width:480px;max-height:85vh;overflow-y:auto;animation:slideUp .25s cubic-bezier(.22,1,.36,1);}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:12px auto 16px;}
.modal-head{padding:0 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:16px;}
.modal-av{width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#fff;flex-shrink:0;overflow:hidden;}
.modal-av img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.modal-av.blue{background:linear-gradient(135deg,var(--cobalt),var(--blue));}
.modal-av.you{background:linear-gradient(135deg,#8b6914,var(--accent));color:var(--navy);}
.modal-av.pur{background:linear-gradient(135deg,var(--pur),var(--pur2));}
.modal-name{font-weight:700;font-size:1.15rem;margin-bottom:2px;}
.modal-ntrp{font-family:'JetBrains Mono',monospace;font-size:.74rem;color:var(--sub);}
.modal-cap{display:inline-flex;align-items:center;gap:4px;font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:10px;background:rgba(201,168,76,.15);color:var(--accent);margin-top:4px;}
.modal-body{padding:20px 24px;}
.modal-sec{margin-bottom:18px;}
.modal-label{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--sub);margin-bottom:8px;}
.modal-bio{font-size:.9rem;line-height:1.65;color:var(--text);}
.mstat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.mstat{background:var(--off);border-radius:10px;padding:14px 10px;text-align:center;}
.mstat-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--text);}
.mstat-val.gold{color:var(--accent)}
.mstat-label{font-family:'JetBrains Mono',monospace;font-size:.54rem;letter-spacing:1px;text-transform:uppercase;color:var(--sub);margin-top:2px;}
.modal-close{display:block;width:calc(100% - 48px);margin:0 24px 24px;padding:14px;background:var(--navy);color:var(--white);border:none;border-radius:12px;font-family:'Inter',sans-serif;font-size:.92rem;font-weight:600;cursor:pointer;}
.photo-upload{display:flex;align-items:center;gap:12px;padding:14px;background:var(--off);border:1px dashed var(--border);border-radius:10px;cursor:pointer;}
.search-overlay{position:fixed;inset:0;background:rgba(6,15,30,.97);z-index:600;display:none;flex-direction:column;padding:20px;}
.search-overlay.open{display:flex;animation:fadeIn .2s ease;}
.search-header{display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.search-field{flex:1;display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 16px;}
.search-field input{flex:1;background:none;border:none;outline:none;color:var(--white);font-family:'Inter',sans-serif;font-size:.95rem;}
.search-field input::placeholder{color:rgba(255,255,255,.3);}
.search-cancel{color:var(--accent);font-weight:600;cursor:pointer;background:none;border:none;font-size:.9rem;}
.search-results{flex:1;overflow-y:auto;}
.s-sec-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.28);padding:12px 0 6px;}
.s-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.06);cursor:pointer;}
.s-av{width:38px;height:38px;border-radius:9px;background:linear-gradient(135deg,var(--cobalt),var(--blue));display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:.9rem;color:#fff;flex-shrink:0;}
.s-av.team{background:linear-gradient(135deg,#1a3a1a,#1e6b1e);}
.s-info{flex:1;}
.s-name{font-size:.9rem;font-weight:600;color:var(--white);}
.s-sub{font-size:.74rem;color:rgba(255,255,255,.38);margin-top:1px;}
.s-tag{font-size:.64rem;font-weight:700;padding:2px 8px;border-radius:4px;background:rgba(201,168,76,.15);color:var(--accent);}
.team-panel{display:none;}.team-panel.active{display:block;}
.page-view{display:none;}.page-view.active{display:block;}
.app-footer{background:var(--navy);color:rgba(255,255,255,.22);text-align:center;padding:20px;font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:2px;border-top:1px solid rgba(255,255,255,.04);margin-top:40px;}
.app-footer strong{color:rgba(255,255,255,.45);font-family:'Bebas Neue',sans-serif;font-size:.85rem;letter-spacing:3px;}
@media(max-width:768px){
  /* Header — compact and prevent wrapping */
  .header-inner{padding:10px 12px;gap:6px;flex-wrap:nowrap;}
  .header-inner > div:last-child{gap:6px !important;flex-shrink:0;}
  .header-inner a,
  .header-inner span,
  .header-inner button,
  .header-inner form,
  .header-inner form button{
    white-space:nowrap !important;
    flex-shrink:0;
    font-size:.6rem !important;
    padding:5px 10px !important;
    letter-spacing:.5px !important;
  }
  .header-inner form{margin:0;display:inline-flex;}
  .logo{gap:8px;flex-shrink:0;}
  .logo-name{font-size:1.2rem;letter-spacing:2px;line-height:1;}
  .logo-mark{width:34px;height:34px;font-size:1rem;}
  .search-btn{width:32px;height:32px;font-size:.85rem;flex-shrink:0;}

  /* Top tabs — horizontally scrollable, no wrapping */
  .team-tabs{
    padding:0 12px;
    overflow-x:auto;
    overflow-y:hidden;
    -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
    flex-wrap:nowrap;
  }
  .team-tabs::-webkit-scrollbar{display:none;}
  .team-tab{
    white-space:nowrap !important;
    flex-shrink:0;
    padding:14px 16px;
    font-size:.72rem;
    letter-spacing:.6px;
  }

  /* Body and hero */
  .app-body{padding:0 14px;padding-bottom:90px;}
  .team-hero{margin:14px 0 0;padding:30px 22px 26px;border-radius:14px;}
  .th-name{font-size:2rem;letter-spacing:3px;}
  .th-tag{font-size:.58rem;}
  .th-sub{font-size:.78rem;}
  .th-content{flex-direction:column;gap:18px;}
  .th-stats{gap:0;justify-content:space-around;width:100%;}
  .th-stat{padding:0 14px 0 0;margin-right:14px;}
  .th-sv{font-size:1.8rem;}

  /* Layout */
  .two-col{grid-template-columns:1fr;gap:16px;}
  .quick-stats{grid-template-columns:repeat(2,1fr);gap:10px;}
  .qs{padding:14px;}
  .qs-val{font-size:1.6rem;}

  /* Hide desktop nav, show mobile nav */
  .desktop-nav{display:none;}
  .mobile-nav{display:block;}

  /* Roster grid — 2 columns on mobile */
  .roster-grid{grid-template-columns:repeat(2,1fr);gap:10px;}
  .roster-card{padding:14px 10px;}
  .ravatar{width:48px;height:48px;font-size:.95rem;}
  .rname{font-size:.82rem;}
  .rntrp{font-size:.65rem;}

  /* Hide season pill on mobile (saves space) */
  .season-pill{display:none;}

  /* Footer with extra space for bottom nav */
  .app-footer{margin-bottom:70px;}

  /* Standings table — make scrollable */
  .stand-table{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  .stand-table table{min-width:480px;}

  /* Sub-tabs scrollable */
