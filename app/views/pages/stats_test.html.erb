<% content_for(:title) { "Stats Test - Court Report" } %>

<style>
  .stats-wrap {
    max-width: 1100px;
    margin: 40px auto;
    padding: 0 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #fff;
  }
  .stats-header {
    margin-bottom: 24px;
  }
  .stats-header h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .stats-header p {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
  }
  .stats-source {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.75rem;
    color: #ccff00;
    text-decoration: none;
    border: 1px solid rgba(204,255,0,0.3);
    padding: 3px 10px;
    border-radius: 12px;
  }
  .stats-error {
    background: rgba(255,68,68,0.1);
    border: 1px solid rgba(255,68,68,0.3);
    color: #ff8080;
    padding: 14px 18px;
    border-radius: 10px;
    margin-bottom: 20px;
  }
  .stats-table-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.03);
  }
  .stats-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }
  .stats-table th {
    text-align: left;
    padding: 12px 16px;
    background: rgba(0,0,0,0.3);
    color: #ccff00;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    white-space: nowrap;
  }
  .stats-table td {
    padding: 12px 16px;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.85);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    white-space: nowrap;
  }
  .stats-table tr:last-child td { border-bottom: none; }
  .stats-table tr:hover td { background: rgba(255,255,255,0.03); }
  .result-win { color: #86efac; font-weight: 700; }
  .result-loss { color: #fca5a5; font-weight: 700; }
  .stats-count {
    margin-top: 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }
  @media (max-width: 600px) {
    .stats-wrap { padding: 0 12px; margin: 20px auto; }
    .stats-header h1 { font-size: 1.5rem; }
    .stats-table th, .stats-table td { padding: 10px 12px; font-size: 0.78rem; }
  }
</style>

<div class="stats-wrap">
  <div class="stats-header">
    <h1>Stats Test Page</h1>
    <p>Live data pulled directly from Google Sheets on every page load.</p>
    <a class="stats-source" href="https://docs.google.com/spreadsheets/d/1OvOObnk_Sq5wZOX8sQHnUfn_PNTXrgSgGnqqS8QeIjI/edit" target="_blank" rel="noopener">View source sheet &rarr;</a>
  </div>

  <% if @error %>
    <div class="stats-error"><%= @error %></div>
  <% elsif @rows.any? %>
    <div class="stats-table-wrap">
      <table class="stats-table">
        <thead>
          <tr>
            <% @headers.each do |header| %>
              <th><%= header %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @rows.each do |row| %>
            <tr>
              <% @headers.each do |header| %>
                <% value = row[header] %>
                <% css_class = if header.to_s.downcase.include?("result")
                     value.to_s.upcase == "WIN" ? "result-win" : "result-loss"
                   end %>
                <td class="<%= css_class %>"><%= value %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="stats-count"><%= @rows.count %> rows loaded from Google Sheets</div>
  <% else %>
    <div class="stats-error">No data found in the sheet.</div>
  <% end %>
</div>
