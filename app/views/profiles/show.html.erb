<% content_for :title, "#{@user.name} · Player Profile" %>

<div class="profile-page">

  <%# ── Header ─────────────────────────────────────────────────────── %>
  <div class="profile-header">
    <div class="profile-identity">
      <h1><%= @user.name %></h1>
      <div class="profile-meta">
        <% if @user.location.present? %>
          <span class="meta-chip">📍 <%= @user.location %></span>
        <% end %>
        <span class="meta-chip">Female</span>
        <span class="meta-chip">Middle States / Philadelphia / Area</span>
      </div>
    </div>

    <div class="rating-cards">
      <% if @user.ntrp_rating.present? %>
        <div class="rating-card rating-card-ntrp">
          <div class="rating-card-label">NTRP Rating</div>
          <div class="rating-card-value"><%= @user.ntrp_rating %></div>
          <% if @user.ntrp_rating_date.present? %>
            <div class="rating-card-date">as of <%= @user.ntrp_rating_date.strftime("%-m/%-d/%Y") %></div>
          <% end %>

          <%# Rating meter — band 3.5001–4.0000 %>
          <% if @user.ntrp_rating.present? %>
            <% band_min = 3.5001; band_max = 4.0000 %>
            <% pct = ((@user.ntrp_rating.to_f - band_min) / (band_max - band_min) * 100).clamp(0, 100).round %>
            <div class="rating-meter">
              <div class="rating-meter-track">
                <div class="rating-meter-fill" style="width: <%= pct %>%"></div>
                <div class="rating-meter-thumb" style="left: <%= pct %>%"></div>
              </div>
              <div class="rating-meter-labels">
                <span>3.5001</span>
                <span>4.0 Band</span>
                <span>4.0000</span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @user.dynamic_rating.present? %>
        <div class="rating-card rating-card-dynamic">
          <div class="rating-card-label">Estimated Dynamic Rating</div>
          <div class="rating-card-value"><%= sprintf("%.2f", @user.dynamic_rating) %></div>
          <% if @user.dynamic_rating_date.present? %>
            <div class="rating-card-date">as of <%= @user.dynamic_rating_date.strftime("%-m/%-d/%Y") %></div>
          <% end %>
          <div class="rating-card-subrow">
            <span class="rating-card-sublabel">Projected Year End</span>
            <span class="rating-card-subdash">—</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Recent Teams ────────────────────────────────────────────────── %>
  <% if @teams.any? %>
    <section class="profile-section">
      <h2 class="section-title">Recent Teams</h2>
      <div class="profile-table-wrap">
        <table class="profile-table">
          <thead>
            <tr>
              <th>Team</th>
              <th>Type</th>
              <th>Section</th>
              <th>Gender</th>
              <th>Rating</th>
              <th>Match Start</th>
            </tr>
          </thead>
          <tbody>
            <% @teams.each do |team| %>
              <tr>
                <td class="td-primary"><%= team.name %></td>
                <td><%= team.team_type %></td>
                <td><%= team.section %></td>
                <td><%= team.gender %></td>
                <td><span class="rating-pill"><%= team.rating %></span></td>
                <td class="td-muted"><%= team.start_date.strftime("%-m/%-d/%Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <%# ── Match History ────────────────────────────────────────────────── %>
  <% if @stats.any? %>
    <section class="profile-section">
      <h2 class="section-title">Match History</h2>
      <div class="profile-table-wrap">
        <table class="profile-table stats-table">
          <thead>
            <tr>
              <th rowspan="2">Year</th>
              <th colspan="4" class="group-header">Matches</th>
              <th colspan="4" class="group-header">Sets</th>
              <th colspan="4" class="group-header">Games</th>
              <th rowspan="2">Defaults</th>
            </tr>
            <tr>
              <th>Total</th><th>W</th><th>L</th><th>W%</th>
              <th>Total</th><th>W</th><th>L</th><th>W%</th>
              <th>Total</th><th>W</th><th>L</th><th>W%</th>
            </tr>
          </thead>
          <tbody>
            <% @stats.each do |s| %>
              <tr>
                <td class="td-year"><%= s.year %></td>
                <%# Matches %>
                <td><%= s.matches_total || "—" %></td>
                <td class="td-win"><%= s.matches_won  || "—" %></td>
                <td class="td-loss"><%= s.matches_lost || "—" %></td>
                <td class="td-pct"><%= s.match_wpct ? "#{s.match_wpct}%" : "—" %></td>
                <%# Sets %>
                <td><%= s.sets_total || "—" %></td>
                <td class="td-win"><%= s.sets_won  || "—" %></td>
                <td class="td-loss"><%= s.sets_lost || "—" %></td>
                <td class="td-pct"><%= s.set_wpct ? "#{s.set_wpct}%" : "—" %></td>
                <%# Games %>
                <td><%= s.games_total || "—" %></td>
                <td class="td-win"><%= s.games_won  || "—" %></td>
                <td class="td-loss"><%= s.games_lost || "—" %></td>
                <td class="td-pct"><%= s.game_wpct ? "#{s.game_wpct}%" : "—" %></td>
                <td><%= s.defaults || "—" %></td>
              </tr>
            <% end %>
          </tbody>
          <% if @totals %>
            <tfoot>
              <tr class="totals-row">
                <td class="td-year">Total</td>
                <td><%= @totals[:matches_total] %></td>
                <td class="td-win"><%= @totals[:matches_won] %></td>
                <td class="td-loss"><%= @totals[:matches_lost] %></td>
                <td class="td-pct">
                  <% if @totals[:matches_total]&.positive? %>
                    <%= (@totals[:matches_won].to_f / @totals[:matches_total] * 100).round(2) %>%
                  <% else %>—<% end %>
                </td>
                <td><%= @totals[:sets_total] || "—" %></td>
                <td class="td-win"><%= @totals[:sets_won]  || "—" %></td>
                <td class="td-loss"><%= @totals[:sets_lost] || "—" %></td>
                <td class="td-pct">
                  <% if @totals[:sets_total]&.positive? %>
                    <%= (@totals[:sets_won].to_f / @totals[:sets_total] * 100).round(2) %>%
                  <% else %>—<% end %>
                </td>
                <td><%= @totals[:games_total] || "—" %></td>
                <td class="td-win"><%= @totals[:games_won]  || "—" %></td>
                <td class="td-loss"><%= @totals[:games_lost] || "—" %></td>
                <td class="td-pct">
                  <% if @totals[:games_total]&.positive? %>
                    <%= (@totals[:games_won].to_f / @totals[:games_total] * 100).round(2) %>%
                  <% else %>—<% end %>
                </td>
                <td><%= @totals[:defaults] || "—" %></td>
              </tr>
            </tfoot>
          <% end %>
        </table>
      </div>
      <p class="stats-note">Full sets &amp; games data for 2024–2025 can be added from the Players admin panel.</p>
    </section>
  <% else %>
    <div class="profile-empty">
      <p>No match history yet.</p>
    </div>
  <% end %>

</div>
