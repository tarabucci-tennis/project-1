<% content_for :title, "#{@user.name} · Court Report" %>

<div class="cr-profile-page">

  <div class="cr-profile-header">
    <div style="flex: 1; min-width: 240px;">
      <h1 style="font-size: 2rem; font-weight: 900; letter-spacing: 0.5px; margin-bottom: 8px; text-transform: uppercase;">
        <%= @user.name %>
      </h1>
      <div class="cr-profile-meta">
        <% if @user.location.present? %>
          <span class="cr-profile-chip">📍 <%= @user.location %></span>
        <% end %>
        <span class="cr-profile-chip">Middle States / Philadelphia</span>
      </div>
    </div>

    <% if @user.ntrp_rating.present? %>
      <div class="cr-rating-card">
        <div class="cr-rating-card-label">NTRP Rating</div>
        <div class="cr-rating-card-value"><%= @user.ntrp_rating %></div>
        <% if @user.ntrp_rating_date.present? %>
          <div class="cr-rating-card-date">
            as of <%= @user.ntrp_rating_date.strftime("%-m/%-d/%Y") %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @user.dynamic_rating.present? %>
      <div class="cr-rating-card">
        <div class="cr-rating-card-label">Dynamic</div>
        <div class="cr-rating-card-value"><%= sprintf("%.2f", @user.dynamic_rating) %></div>
        <% if @user.dynamic_rating_date.present? %>
          <div class="cr-rating-card-date">
            as of <%= @user.dynamic_rating_date.strftime("%-m/%-d/%Y") %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Teams list ── %>
  <% if @teams.any? %>
    <section class="cr-section">
      <h2 class="cr-section-title">My Teams</h2>
      <table class="cr-table">
        <thead>
          <tr>
            <th>Team</th>
            <th>League</th>
            <th>Type</th>
            <th>Rating</th>
          </tr>
        </thead>
        <tbody>
          <% @teams.each do |team| %>
            <tr>
              <td style="font-weight: 700;">
                <%= link_to team.name, team_path(team), style: "color: var(--cr-text);" %>
              </td>
              <td style="color: var(--cr-gold); font-weight: 700;">
                <%= team.league_category == "Local" ? "Del-Tri" : team.league_category %>
              </td>
              <td style="color: var(--cr-text-muted);"><%= team.team_type %></td>
              <td>
                <% if team.rating.present? %>
                  <span class="cr-roster-rating"><%= team.rating %></span>
                <% else %>
                  —
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>

  <%# ── Match History ── %>
  <% if @stats.any? %>
    <section class="cr-section">
      <h2 class="cr-section-title">Match History</h2>
      <table class="cr-table">
        <thead>
          <tr>
            <th>Year</th>
            <th>Matches</th>
            <th>Won</th>
            <th>Lost</th>
            <th>Win %</th>
          </tr>
        </thead>
        <tbody>
          <% @stats.each do |s| %>
            <tr>
              <td style="font-weight: 700; color: var(--cr-gold);"><%= s.year %></td>
              <td><%= s.matches_total || "—" %></td>
              <td style="color: var(--cr-green);"><%= s.matches_won || "—" %></td>
              <td style="color: var(--cr-red);"><%= s.matches_lost || "—" %></td>
              <td><%= s.match_wpct ? "#{s.match_wpct}%" : "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
</div>
