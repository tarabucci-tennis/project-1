<% content_for(:title) { "My Teams - Court Report" } %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
  <div>
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:4px;">My Teams</h1>
  </div>
  <a href="<%= new_team_path %>" class="cr-btn">+ Create Team</a>
</div>

<% if @my_teams.empty? %>
  <div class="cr-card" style="text-align:center;padding:60px 24px;">
    <p style="font-size:1.2rem;margin-bottom:12px;">You haven't joined any teams yet</p>
    <p style="color:var(--sub);margin-bottom:20px;">Ask your captain for a join link or create your own team to get started.</p>
    <a href="<%= new_team_path %>" class="cr-btn">+ Create Team</a>
  </div>
<% else %>
  <% @leagues.each do |league, teams| %>
    <div class="cr-league-label"><%= league || "Other" %></div>
    <div class="cr-team-grid">
      <% teams.each do |team| %>
        <a href="<%= team_path(team) %>" class="cr-team-card">
          <div class="cr-team-card-league"><%= team.league %> <% if team.usta_team_number.present? %>· #<%= team.usta_team_number %><% end %></div>
          <div class="cr-team-card-name"><%= team.name %></div>
          <div class="cr-team-card-meta">
            <%= team.roster_count %> players · <%= team.scheduled_matches.upcoming.count %> upcoming
            <% if current_user.captain_of?(team) %>
              · <span style="color:var(--accent);">Captain</span>
            <% end %>
          </div>
          <% r = team.record %>
          <div class="cr-team-card-record"><%= r[:wins] %>–<%= r[:losses] %></div>
        </a>
      <% end %>
    </div>
  <% end %>
<% end %>
