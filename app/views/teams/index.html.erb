<% content_for :title, "My Teams · Court Report" %>

<div class="cr-page-header">
  <h1 class="cr-page-title">My Teams</h1>
</div>

<% any_teams = @teams_by_league.values.flatten.any? %>

<% if any_teams %>
  <div class="cr-leagues-grid">
    <% @teams_by_league.each do |league_key, teams| %>
      <% next if teams.empty? %>
      <section class="cr-league-section">
        <div class="cr-league-label">
          <%= league_key == "Local" ? "Local Leagues" : league_key %>
        </div>
        <div class="cr-team-cards">
          <% teams.each do |team| %>
            <%= link_to team_path(team), class: "cr-team-card" do %>
              <div class="cr-team-card-league">
                <%= team.league_category == "Local" ? "Del-Tri" : team.league_category %>
              </div>
              <h2 class="cr-team-card-name"><%= team.name %></h2>
              <div class="cr-team-card-meta">
                <span><%= team.team_memberships.count %> players · <%= team.upcoming_matches.count %> upcoming</span>
                <span class="cr-team-card-record">0-0</span>
              </div>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <div class="cr-empty">
    <p>You haven't joined any teams yet.</p>
  </div>
<% end %>
