<% content_for :title, "Find a Team · Court Report" %>

<div class="cr-page" style="max-width: 600px; margin: 0 auto; padding: 32px 24px;">
  <h1 class="cr-page-title" style="margin-bottom: 8px;"><span class="cr-bounce">🎾</span> Find a Team</h1>
  <p style="color: var(--cr-text-muted); font-size: 0.9rem; margin-bottom: 24px;">
    Search by team name to find and join your team.
  </p>

  <%= form_with url: find_team_path, method: :get, local: true do |f| %>
    <div style="display: flex; gap: 8px;">
      <%= f.search_field :q, value: @query, placeholder: "e.g. Kiss My Ace, Pour Decisions...",
          style: "flex: 1; padding: 12px 16px; border: 1px solid var(--cr-border); border-radius: 8px; font-size: 1rem; outline: none; background: var(--cr-white);" %>
      <%= f.submit "Search", class: "cr-btn cr-btn-gold", style: "padding: 12px 24px;" %>
    </div>
  <% end %>

  <% if @query.present? %>
    <div style="margin-top: 24px;">
      <% if @results.any? %>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <% @results.each do |team| %>
            <% joined = team.team_memberships.exists?(user: current_user) %>
            <div class="cr-match-card"
                 style="padding: 14px 18px;<%= ' cursor: pointer;' if joined %>"
                 <%= "onclick=\"location.href='#{team_path(team)}'\" role=\"link\" tabindex=\"0\"".html_safe if joined %>>
              <div style="display: flex; align-items: center; justify-content: space-between;">
                <div>
                  <div style="font-size: 0.6rem; font-weight: 700; color: var(--cr-gold); letter-spacing: 1px; text-transform: uppercase;">
                    <%= team.league_category == "Local" ? "DEL-TRI" : team.league_category %>
                  </div>
                  <div style="font-weight: 700; font-size: 0.95rem;"><%= team.name %></div>
                  <div style="font-size: 0.8rem; color: var(--cr-text-muted);">
                    <%= team.team_memberships.active.count %> players
                    <% if team.section.present? %>· <%= team.section %><% end %>
                    <% if team.rating.present? %>· <%= team.rating %><% end %>
                  </div>
                </div>
                <% if joined %>
                  <span style="font-size: 0.8rem; color: var(--cr-green); font-weight: 600;">Joined</span>
                <% else %>
                  <%= button_to "Join", join_team_path(team.ensure_join_code!), method: :get,
                      class: "cr-btn cr-btn-gold", style: "padding: 8px 20px; font-size: 0.8rem;" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div style="text-align: center; padding: 40px 20px; color: var(--cr-text-light);">
          <p>No teams found for "<%= @query %>"</p>
          <p style="margin-top: 8px; font-size: 0.85rem;">
            Don't see your team? <%= link_to "Create it", new_team_path, style: "color: var(--cr-gold); font-weight: 600;" %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>

  <div style="text-align: center; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--cr-border);">
    <p style="font-size: 0.9rem; color: var(--cr-text-muted); margin-bottom: 12px;">
      Want to start a new team?
    </p>
    <%= link_to "Create a Team", new_team_path, class: "cr-btn cr-btn-outline", style: "padding: 10px 24px;" %>
  </div>
</div>
