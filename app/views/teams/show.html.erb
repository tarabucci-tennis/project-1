<% content_for :title, "#{@team.name} · Court Report" %>

<div class="cr-team-page">

  <%= link_to "← My Teams", teams_path, class: "cr-back-link" %>

  <%# ── Hero ────────────────────────────────────────── %>
  <div class="cr-team-hero">
    <div class="cr-team-hero-content">
      <div class="cr-team-hero-label">
        — <%= @team.name %>
        <% if @captain %>
          · Captain: <%= @captain.name %>
        <% end %>
        <% if @team.team_type.present? %>
          · <%= @team.team_type %>
        <% end %>
      </div>

      <h1 class="cr-team-hero-name"><%= @team.name %></h1>

      <div class="cr-team-hero-sub">
        <% if @team.home_court.present? %>
          <%= @team.home_court.split(",").first %>
        <% end %>
        <% if @team.rating.present? %>
          · <%= @team.section %> <%= @team.rating %> <%= @team.gender == "F" ? "Women's" : "Men's" %>
        <% else %>
          · <%= @team.section %>
        <% end %>
        <% if @team.season_name.present? %>
          · <%= @team.season_name %>
        <% end %>
      </div>

      <div class="cr-team-hero-stats">
        <div class="cr-hero-stat">
          <div class="cr-hero-stat-value"><%= @wins %>-<%= @losses %></div>
          <div class="cr-hero-stat-label">Record</div>
        </div>
        <div class="cr-hero-stat">
          <div class="cr-hero-stat-value"><%= @upcoming_matches.count + @past_matches.count %></div>
          <div class="cr-hero-stat-label">Matches</div>
        </div>
        <% if @team.next_match %>
          <div class="cr-hero-stat">
            <div class="cr-hero-stat-value"><%= @team.next_match.match_date.strftime("%b %-d").upcase %></div>
            <div class="cr-hero-stat-label">Starts</div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Stat cards ───────────────────────────────────── %>
  <div class="cr-stat-cards">
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @wins %></div>
      <div class="cr-stat-card-label">Wins</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @losses %></div>
      <div class="cr-stat-card-label">Losses</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @upcoming_matches.count %></div>
      <div class="cr-stat-card-label">Scheduled</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @player_count %></div>
      <div class="cr-stat-card-label">Players</div>
    </div>
  </div>

  <%# ── Sub-tabs ─────────────────────────────────────── %>
  <div data-controller="team-tabs">
    <div class="cr-subtabs">
      <button class="cr-subtab cr-subtab-active" data-team-tabs-target="tab" data-action="click->team-tabs#switch">📅 Schedule</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">✋ Availability</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">👥 Roster</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">📊 Player Stats</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">🏆 Standings</button>
      <% if @is_captain %>
        <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">👑 Captain</button>
      <% end %>
    </div>

    <%# ── Tab 1: Schedule (clean — no availability buttons) ── %>
    <div data-team-tabs-target="panel">
      <div class="cr-schedule-layout">
        <%# Left: upcoming matches %>
        <div>
          <h2 class="cr-section-title">
            <%= @team.season_name.present? ? @team.season_name : "" %> Schedule
          </h2>
          <% all_matches = (@upcoming_matches + @past_matches).sort_by(&:match_date) %>
          <% if all_matches.any? %>
            <div class="cr-match-list">
              <% all_matches.each do |match| %>
                <div class="cr-match-card" style="padding: 12px 16px;">
                  <div class="cr-match-row">
                    <div class="cr-match-date">
                      <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                      <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                    </div>
                    <div class="cr-match-info">
                      <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                      <div class="cr-match-location">
                        <%= match.location %>
                        <% if match.match_time.present? %>
                          · <%= match.match_time %>
                        <% end %>
                      </div>
                    </div>
                    <% if match.notes&.include?("Home") || match.location&.include?(@team.home_court.to_s.split(",").first.to_s) %>
                      <div class="cr-match-badge cr-match-home">Home</div>
                    <% elsif match.notes&.include?("Away") %>
                      <div class="cr-match-badge cr-match-away">Away</div>
                    <% end %>
                    <a href="<%= google_calendar_url(match) %>"
                       target="_blank" rel="noopener"
                       class="cr-cal-btn"
                       title="Add to Google Calendar"
                       onclick="event.stopPropagation();">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                      </svg>
                    </a>
                    <% if match.played? %>
                      <div class="cr-match-result-row">
                        <span class="cr-result-badge <%= match.won? ? 'cr-result-badge-win' : 'cr-result-badge-loss' %>">
                          <%= match.result_label %>
                        </span>
                        <% if match.score_summary.present? %>
                          <span class="cr-result-score"><%= match.score_summary %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>

                  <%# Show published lineup if one exists %>
                  <% lineup = match.lineup if match.respond_to?(:lineup) %>
                  <% if lineup&.published? %>
                    <div class="cr-lineup-preview">
                      <div class="cr-lineup-preview-title">Lineup Posted</div>
                      <div class="cr-lineup-preview-slots">
                        <% lineup.lineup_slots.includes(:user).order(position: :asc).group_by { |s| "#{s.position}#{s.line_type == 'singles' ? 'S' : 'D'}" }.each do |line, slots| %>
                          <div class="cr-lineup-preview-line">
                            <span class="cr-lineup-preview-line-label"><%= line %></span>
                            <% slots.each do |slot| %>
                              <span class="cr-lineup-preview-player <%= 'cr-lineup-you' if slot.user_id == current_user.id %>">
                                <%= slot.user.name.split.first %>
                                <% if slot.confirmed? %>
                                  <span class="cr-lineup-confirmed">✓</span>
                                <% elsif slot.declined? %>
                                  <span class="cr-lineup-declined">✗</span>
                                <% end %>
                              </span>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                      <% my_slot = lineup.slot_for(current_user) %>
                      <% if my_slot && my_slot.pending? %>
                        <div class="cr-lineup-confirm-row">
                          <span style="font-size: 0.85rem; font-weight: 600;">You're on <strong><%= my_slot.line_label %></strong> — can you play?</span>
                          <%= link_to "✓ Confirm", confirm_team_match_lineup_path(@team, match, status: "confirmed"), method: :patch, class: "cr-btn cr-btn-gold", style: "padding: 6px 16px; font-size: 0.8rem;" %>
                          <%= link_to "✗ Can't Play", confirm_team_match_lineup_path(@team, match, status: "declined"), method: :patch, class: "cr-btn cr-btn-outline", style: "padding: 6px 16px; font-size: 0.8rem;" %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="cr-empty" style="padding: 40px 20px;">
              <p>No matches scheduled yet.</p>
            </div>
          <% end %>
        </div>

        <%# Right: results summary %>
        <div>
          <h2 class="cr-section-title">Results</h2>
          <div class="cr-results-placeholder">
            <% completed_matches = @past_matches.select(&:played?) %>
            <% if completed_matches.any? %>
              <% completed_matches.each do |match| %>
                <div class="cr-match-card" style="padding: 12px 16px;">
                  <div class="cr-match-row">
                    <div class="cr-match-date">
                      <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                      <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                    </div>
                    <div class="cr-match-info">
                      <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                      <div class="cr-match-result-row">
                        <span class="cr-result-badge <%= match.won? ? 'cr-result-badge-win' : 'cr-result-badge-loss' %>">
                          <%= match.result_label %>
                        </span>
                        <% if match.score_summary.present? %>
                          <span class="cr-result-score"><%= match.score_summary %></span>
                        <% end %>
                      </div>
                    </div>
                    <% if @is_captain %>
                      <%= link_to "Edit", edit_results_team_match_path(@team, match), class: "cr-enter-results-link" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <div style="text-align: center; padding: 40px 20px; color: var(--cr-text-light);">
                🎾 Season starts <%= @team.next_match ? @team.next_match.match_date.strftime("%B %-d") : "soon" %>!
                <div style="margin-top: 8px; font-size: 0.85rem;">Results will appear here after each match.</div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# ── Tab 2: Availability ────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">My Availability</h2>
        <p style="font-size: 0.85rem; color: var(--cr-text-muted); margin-bottom: 16px;">
          Let your captain know if you can play each match.
        </p>
        <% if @upcoming_matches.any? %>
          <div class="cr-match-list">
            <% @upcoming_matches.each do |match| %>
              <% avail = @my_availabilities[match.id] %>
              <% current_status = avail&.status || "no_response" %>
              <% current_message = avail&.message || "" %>

              <div class="cr-match-card"
                   data-controller="availability"
                   data-availability-match-id-value="<%= match.id %>"
                   data-availability-status-value="<%= current_status %>"
                   data-availability-message-value="<%= current_message %>">

                <div class="cr-match-row">
                  <div class="cr-match-date">
                    <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                    <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                  </div>
                  <div class="cr-match-info">
                    <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                    <div class="cr-match-location"><%= match.location %></div>
                  </div>
                  <% if match.notes&.include?("Home") || match.location&.include?(@team.home_court.to_s.split(",").first.to_s) %>
                    <div class="cr-match-badge cr-match-home">Home</div>
                  <% elsif match.notes&.include?("Away") %>
                    <div class="cr-match-badge cr-match-away">Away</div>
                  <% end %>
                </div>

                <div class="cr-avail-row">
                  <button type="button"
                          class="cr-avail-btn cr-avail-in <%= 'avail-btn-active avail-btn-locked' if current_status == 'in' %>"
                          data-availability-target="btnIn"
                          data-action="click->availability#markIn">
                    ✅ I'm In
                  </button>
                  <button type="button"
                          class="cr-avail-btn cr-avail-out <%= 'avail-btn-active avail-btn-locked' if current_status == 'out' %>"
                          data-availability-target="btnOut"
                          data-action="click->availability#markOut">
                    ❌ I'm Out
                  </button>
                  <input type="text"
                         class="cr-avail-message"
                         placeholder="Add a message..."
                         value="<%= current_message %>"
                         data-availability-target="messageField"
                         data-action="keydown->availability#saveMessage blur->availability#saveMessage">
                  <span class="cr-saved" data-availability-target="savedIndicator"></span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="cr-empty" style="padding: 40px 20px;">
            <p>No upcoming matches to respond to.</p>
          </div>
        <% end %>
      </section>
    </div>

    <%# ── Tab 2: Roster ──────────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">Roster (<%= @player_count %> Players)</h2>
        <div class="cr-roster">
          <% @roster.each do |membership| %>
            <%= link_to player_path(membership.user), class: "cr-roster-row", style: "text-decoration: none; color: inherit;" do %>
              <div class="cr-roster-name <%= 'cr-roster-self' if membership.user_id == current_user.id %>">
                <%= membership.user.name %>
                <% if membership.user_id == current_user.id %>
                  (you)
                <% end %>
              </div>
              <% if membership.user.ntrp_rating.present? %>
                <div class="cr-roster-rating"><%= membership.user.ntrp_rating %></div>
              <% end %>
              <% if membership.captain? %>
                <div class="cr-roster-role cr-roster-role-captain">Captain</div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </section>
    </div>

    <%# ── Tab 4: Player Stats ──────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">Player Stats</h2>

        <% if @player_stats_data.present? && @player_stats_data.any? %>
          <%# Stats grid like your captain's spreadsheet %>
          <div class="cr-captain-analytics-table">
            <div class="cr-captain-analytics-header">
              <span class="cr-captain-col-name">Player</span>
              <span class="cr-captain-col-stat">Played</span>
              <span class="cr-captain-col-stat">W</span>
              <span class="cr-captain-col-stat">L</span>
              <span class="cr-captain-col-stat">Win%</span>
              <span class="cr-captain-col-stat">S%</span>
              <span class="cr-captain-col-stat">D%</span>
              <span class="cr-captain-col-stat">Line</span>
            </div>
            <% @player_stats_data.each do |ps| %>
              <div class="cr-captain-analytics-row">
                <span class="cr-captain-col-name">
                  <%= link_to ps[:name], player_path(ps[:user_id]), style: "text-decoration: none; color: inherit; font-weight: 600;" %>
                  <% if ps[:user_id] == current_user.id %>
                    <span style="color: var(--cr-gold); font-size: 0.75rem;">(you)</span>
                  <% end %>
                </span>
                <span class="cr-captain-col-stat"><%= ps[:matches_played] %></span>
                <span class="cr-captain-col-stat" style="color: var(--cr-green);"><%= ps[:wins] %></span>
                <span class="cr-captain-col-stat" style="color: var(--cr-red);"><%= ps[:losses] %></span>
                <span class="cr-captain-col-stat" style="font-weight: 700;"><%= ps[:win_pct] %>%</span>
                <span class="cr-captain-col-stat"><%= ps[:singles_pct] %>%</span>
                <span class="cr-captain-col-stat"><%= ps[:doubles_pct] %>%</span>
                <span class="cr-captain-col-stat"><%= ps[:most_common_line] || "—" %></span>
              </div>
            <% end %>
          </div>

          <p style="font-size: 0.8rem; color: var(--cr-text-muted); margin-top: 12px;">
            S% = singles percentage · D% = doubles percentage · Line = most played line
            <br>Click a player's name to see their full stats, doubles partner win %, and recent matches.
          </p>
        <% else %>
          <div class="cr-coming-soon-card">
            <div class="cr-coming-soon-icon">📊</div>
            <h3 class="cr-coming-soon-title">Player Stats — Coming Soon</h3>
            <p class="cr-coming-soon-text">
              After each match, your captain enters who played on which line and the scores.
              Court Report will automatically track:
            </p>
            <div class="cr-coming-soon-list">
              <div class="cr-coming-soon-item">Overall Win %</div>
              <div class="cr-coming-soon-item">Singles vs. Doubles %</div>
              <div class="cr-coming-soon-item">Win % by Line (1S, 1D, 2D, 3D, 4D)</div>
              <div class="cr-coming-soon-item">Doubles Partner Win %</div>
              <div class="cr-coming-soon-item">Matches Played per Player</div>
              <div class="cr-coming-soon-item">Recent Match Results</div>
            </div>
            <p class="cr-coming-soon-text" style="margin-top: 16px;">
              Stats will appear here after your first match results are entered.
            </p>
          </div>
        <% end %>
      </section>
    </div>

    <%# ── Tab 5: Standings ───────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">
          <%= @team.league_category == "Local" ? "Del-Tri" : @team.section %> Standings
        </h2>

        <div class="cr-standings-table">
          <div class="cr-standings-header-row">
            <span class="cr-standings-rank-col">#</span>
            <span class="cr-standings-team-col">Team</span>
            <span class="cr-standings-stat-col">W</span>
            <span class="cr-standings-stat-col">L</span>
            <span class="cr-standings-stat-col">Win%</span>
          </div>

          <% @standings.each_with_index do |entry, idx| %>
            <div class="cr-standings-row <%= 'cr-standings-row-self' if entry[:is_self] %>">
              <span class="cr-standings-rank-col"><%= idx + 1 %></span>
              <span class="cr-standings-team-col">
                <%= entry[:name] %>
                <% if entry[:is_self] %>
                  <span class="cr-standings-you-badge">You</span>
                <% end %>
              </span>
              <span class="cr-standings-stat-col cr-standings-wins"><%= entry[:wins] %></span>
              <span class="cr-standings-stat-col cr-standings-losses"><%= entry[:losses] %></span>
              <span class="cr-standings-stat-col">
                <% total = entry[:wins] + entry[:losses] %>
                <% if total > 0 %>
                  <%= sprintf("%.0f%%", entry[:wins].to_f / total * 100) %>
                <% else %>
                  —
                <% end %>
              </span>
            </div>
          <% end %>
        </div>

        <% if @wins == 0 && @losses == 0 && @division_teams.none? { |dt| dt.wins > 0 || dt.losses > 0 } %>
          <div style="text-align: center; padding: 20px; color: var(--cr-text-light); font-size: 0.85rem;">
            🏆 Standings will update as the season progresses.
          </div>
        <% end %>
      </section>
    </div>

    <%# ── Tab 5: Captain (only visible to captains) ──── %>
    <% if @is_captain %>
      <div data-team-tabs-target="panel" style="display: none;">
        <section class="cr-section">
          <h2 class="cr-section-title">Captain Dashboard</h2>
          <p style="font-size: 0.85rem; color: var(--cr-text-muted); margin-bottom: 20px;">
            Only you can see this tab. Your team cannot.
          </p>

          <%# ── Share Join Link + Add Player ── %>
          <div style="display: flex; gap: 16px; margin-bottom: 28px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 250px; background: var(--cr-white); border: 1px solid var(--cr-border); border-radius: 10px; padding: 16px;">
              <div style="font-size: 0.75rem; font-weight: 700; color: var(--cr-text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;">Share Join Link</div>
              <p style="font-size: 0.8rem; color: var(--cr-text-light); margin-bottom: 8px;">Send this link to players so they can join your team:</p>
              <div style="display: flex; gap: 6px;">
                <input type="text" value="<%= join_team_url(@team.ensure_join_code!, host: request.host) %>" readonly
                       style="flex: 1; padding: 8px 10px; font-size: 0.8rem; border: 1px solid var(--cr-border); border-radius: 6px; background: var(--cr-bg); color: var(--cr-text);"
                       onclick="this.select(); document.execCommand('copy');">
              </div>
            </div>

            <div style="flex: 1; min-width: 250px; background: var(--cr-white); border: 1px solid var(--cr-border); border-radius: 10px; padding: 16px;">
              <div style="font-size: 0.75rem; font-weight: 700; color: var(--cr-text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;">Add Player</div>
              <%= form_with url: add_player_team_path(@team), method: :post, local: true do |f| %>
                <div style="display: flex; flex-direction: column; gap: 6px;">
                  <input type="text" name="player_name" placeholder="Name" style="padding: 8px 10px; font-size: 0.85rem; border: 1px solid var(--cr-border); border-radius: 6px;">
                  <input type="email" name="email" placeholder="Email" required style="padding: 8px 10px; font-size: 0.85rem; border: 1px solid var(--cr-border); border-radius: 6px;">
                  <%= f.submit "Add to Roster", class: "cr-btn cr-btn-gold", style: "padding: 8px 16px; font-size: 0.8rem;" %>
                </div>
              <% end %>
            </div>
          </div>

          <%# ── Availability overview for each upcoming match ── %>
          <% if @upcoming_matches.any? %>
            <h3 class="cr-captain-section-title">Upcoming — Who's Available</h3>
            <% @upcoming_matches.each do |match| %>
              <div class="cr-captain-match-card">
                <div class="cr-captain-match-header">
                  <div class="cr-match-date">
                    <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                    <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                  </div>
                  <div class="cr-match-info">
                    <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                    <div class="cr-match-location"><%= match.location %></div>
                  </div>
                  <%= link_to "Set Lineup", edit_team_match_lineup_path(@team, match), class: "cr-btn cr-btn-gold", style: "padding: 8px 16px; font-size: 0.8rem;" %>
                </div>

                <div class="cr-captain-avail-grid">
                  <% counts = match.availability_counts %>
                  <div class="cr-captain-avail-group">
                    <div class="cr-captain-avail-label cr-captain-label-in">In (<%= counts[:in] %>)</div>
                    <% match.availabilities.where(status: "in").includes(:user).each do |a| %>
                      <div class="cr-captain-player-row">
                        <span><%= a.user.name %></span>
                        <% if a.message.present? %>
                          <span class="cr-captain-player-msg">"<%= a.message %>"</span>
                        <% end %>
                      </div>
                    <% end %>
                    <% if counts[:in] == 0 %>
                      <div class="cr-captain-empty">No responses yet</div>
                    <% end %>
                  </div>

                  <div class="cr-captain-avail-group">
                    <div class="cr-captain-avail-label cr-captain-label-out">Out (<%= counts[:out] %>)</div>
                    <% match.availabilities.where(status: "out").includes(:user).each do |a| %>
                      <div class="cr-captain-player-row">
                        <span><%= a.user.name %></span>
                        <% if a.message.present? %>
                          <span class="cr-captain-player-msg">"<%= a.message %>"</span>
                        <% end %>
                      </div>
                    <% end %>
                    <% if counts[:out] == 0 %>
                      <div class="cr-captain-empty">—</div>
                    <% end %>
                  </div>

                  <div class="cr-captain-avail-group">
                    <div class="cr-captain-avail-label cr-captain-label-pending">No Response (<%= counts[:no_response] %>)</div>
                    <% responded_ids = match.availabilities.pluck(:user_id) %>
                    <% @team.members.where.not(id: responded_ids).order(:name).each do |member| %>
                      <div class="cr-captain-player-row cr-captain-player-pending"><%= member.name %></div>
                    <% end %>
                    <% if counts[:no_response] == 0 %>
                      <div class="cr-captain-empty">Everyone responded!</div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>

          <%# ── Player Stats (only shows when matches have been played) ── %>
          <% if @player_analytics.present? && @player_analytics.any? %>
            <h3 class="cr-captain-section-title" style="margin-top: 32px;">Player Analytics</h3>

            <div class="cr-captain-analytics-table">
              <div class="cr-captain-analytics-header">
                <span class="cr-captain-col-name">Player</span>
                <span class="cr-captain-col-stat">Played</span>
                <span class="cr-captain-col-stat">S%</span>
                <span class="cr-captain-col-stat">D%</span>
                <span class="cr-captain-col-stat">Line</span>
                <span class="cr-captain-col-stat">W-L</span>
                <span class="cr-captain-col-stat">Win%</span>
              </div>
              <% @player_analytics.each do |pa| %>
                <div class="cr-captain-analytics-row">
                  <span class="cr-captain-col-name"><%= pa[:name] %></span>
                  <span class="cr-captain-col-stat"><%= pa[:matches_played] %></span>
                  <span class="cr-captain-col-stat"><%= pa[:singles_pct] %>%</span>
                  <span class="cr-captain-col-stat"><%= pa[:doubles_pct] %>%</span>
                  <span class="cr-captain-col-stat"><%= pa[:most_common_line] || "—" %></span>
                  <span class="cr-captain-col-stat"><%= pa[:wins] %>-<%= pa[:losses] %></span>
                  <span class="cr-captain-col-stat"><%= pa[:win_pct] %>%</span>
                </div>
              <% end %>
            </div>

            <%# ── Doubles pairings W/L ── %>
            <% if @doubles_pairings.present? && @doubles_pairings.any? %>
              <h3 class="cr-captain-section-title" style="margin-top: 28px;">Doubles Pairings</h3>
              <div class="cr-captain-analytics-table">
                <div class="cr-captain-analytics-header">
                  <span class="cr-captain-col-name">Pairing</span>
                  <span class="cr-captain-col-stat">Played</span>
                  <span class="cr-captain-col-stat">W-L</span>
                  <span class="cr-captain-col-stat">Win%</span>
                </div>
                <% @doubles_pairings.each do |dp| %>
                  <div class="cr-captain-analytics-row">
                    <span class="cr-captain-col-name"><%= dp[:names] %></span>
                    <span class="cr-captain-col-stat"><%= dp[:played] %></span>
                    <span class="cr-captain-col-stat"><%= dp[:wins] %>-<%= dp[:losses] %></span>
                    <span class="cr-captain-col-stat"><%= dp[:win_pct] %>%</span>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div style="text-align: center; padding: 30px 20px; color: var(--cr-text-light); font-size: 0.85rem; margin-top: 24px; background: var(--cr-white); border-radius: 10px; border: 1px solid var(--cr-border);">
              📊 Player analytics will appear here after match results are entered.
              <div style="margin-top: 6px;">Use "Enter Results" after each match to track who played where.</div>
            </div>
          <% end %>
        </section>
      </div>
    <% end %>
  </div>

</div>
