<% content_for :title, "#{@team.name} · Court Report" %>

<div class="cr-team-page">

  <%= link_to "← My Teams", teams_path, class: "cr-back-link" %>

  <%# ── Hero ────────────────────────────────────────── %>
  <div class="cr-team-hero">
    <div class="cr-team-hero-content">
      <div class="cr-team-hero-label">
        — <%= @team.name %>
        <% if @captain %>
          · Captain: <%= @captain.name %>
        <% end %>
        <% if @team.team_type.present? %>
          · <%= @team.team_type %>
        <% end %>
      </div>

      <h1 class="cr-team-hero-name"><%= @team.name %></h1>

      <div class="cr-team-hero-sub">
        <% if @team.home_court.present? %>
          <%= @team.home_court.split(",").first %>
        <% end %>
        <% if @team.rating.present? %>
          · <%= @team.section %> <%= @team.rating %> <%= @team.gender == "F" ? "Women's" : "Men's" %>
        <% else %>
          · <%= @team.section %>
        <% end %>
        <% if @team.season_name.present? %>
          · <%= @team.season_name %>
        <% end %>
      </div>

      <div class="cr-team-hero-stats">
        <div class="cr-hero-stat">
          <div class="cr-hero-stat-value"><%= @wins %>-<%= @losses %></div>
          <div class="cr-hero-stat-label">Record</div>
        </div>
        <div class="cr-hero-stat">
          <div class="cr-hero-stat-value"><%= @upcoming_matches.count + @past_matches.count %></div>
          <div class="cr-hero-stat-label">Matches</div>
        </div>
        <% if @team.next_match %>
          <div class="cr-hero-stat">
            <div class="cr-hero-stat-value"><%= @team.next_match.match_date.strftime("%b %-d").upcase %></div>
            <div class="cr-hero-stat-label">Starts</div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Stat cards ───────────────────────────────────── %>
  <div class="cr-stat-cards">
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @wins %></div>
      <div class="cr-stat-card-label">Wins</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @losses %></div>
      <div class="cr-stat-card-label">Losses</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @upcoming_matches.count %></div>
      <div class="cr-stat-card-label">Scheduled</div>
    </div>
    <div class="cr-stat-card">
      <div class="cr-stat-card-value"><%= @player_count %></div>
      <div class="cr-stat-card-label">Players</div>
    </div>
  </div>

  <%# ── Sub-tabs ─────────────────────────────────────── %>
  <div data-controller="team-tabs">
    <div class="cr-subtabs">
      <button class="cr-subtab cr-subtab-active" data-team-tabs-target="tab" data-action="click->team-tabs#switch">📅 Schedule</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">👥 Roster</button>
      <button class="cr-subtab" data-team-tabs-target="tab" data-action="click->team-tabs#switch">🏆 Standings</button>
    </div>

    <%# ── Tab 1: Schedule ────────────────────────────── %>
    <div data-team-tabs-target="panel">
      <div class="cr-schedule-layout">
        <%# Left: upcoming matches %>
        <div>
          <h2 class="cr-section-title">
            <%= @team.season_name.present? ? @team.season_name : "" %> Schedule
          </h2>
          <% if @upcoming_matches.any? %>
            <div class="cr-match-list">
              <% @upcoming_matches.each do |match| %>
                <% avail = @my_availabilities[match.id] %>
                <% current_status = avail&.status || "no_response" %>
                <% current_message = avail&.message || "" %>
                <% counts = match.availability_counts %>

                <div class="cr-match-card"
                     data-controller="availability"
                     data-availability-match-id-value="<%= match.id %>"
                     data-availability-status-value="<%= current_status %>"
                     data-availability-message-value="<%= current_message %>">

                  <div class="cr-match-row">
                    <div class="cr-match-date">
                      <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                      <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                    </div>
                    <div class="cr-match-info">
                      <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                      <div class="cr-match-location"><%= match.location %></div>
                    </div>
                    <% if match.notes&.include?("Home") || match.location&.include?(@team.home_court.to_s.split(",").first.to_s) %>
                      <div class="cr-match-badge cr-match-home">Home</div>
                    <% elsif match.notes&.include?("Away") %>
                      <div class="cr-match-badge cr-match-away">Away</div>
                    <% end %>
                    <% if @is_captain %>
                      <div class="cr-match-counts" data-availability-target="counts">
                        <span class="cr-count-in"><%= counts[:in] %> ✅</span>
                        <span class="cr-count-out"><%= counts[:out] %> ❌</span>
                        <span class="cr-count-pending"><%= counts[:no_response] %> ?</span>
                      </div>
                    <% end %>
                  </div>

                  <div class="cr-avail-row">
                    <button type="button"
                            class="cr-avail-btn cr-avail-in <%= 'avail-btn-active avail-btn-locked' if current_status == 'in' %>"
                            data-availability-target="btnIn"
                            data-action="click->availability#markIn">
                      ✅ I'm In
                    </button>
                    <button type="button"
                            class="cr-avail-btn cr-avail-out <%= 'avail-btn-active avail-btn-locked' if current_status == 'out' %>"
                            data-availability-target="btnOut"
                            data-action="click->availability#markOut">
                      ❌ I'm Out
                    </button>
                    <input type="text"
                           class="cr-avail-message"
                           placeholder="Add a message..."
                           value="<%= current_message %>"
                           data-availability-target="messageField"
                           data-action="keydown->availability#saveMessage blur->availability#saveMessage">
                    <span class="cr-saved" data-availability-target="savedIndicator"></span>
                    <% if @is_captain %>
                      <%= link_to "View All", team_captain_path(@team), class: "cr-avail-captain-link" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="cr-empty" style="padding: 40px 20px;">
              <p>No upcoming matches.</p>
            </div>
          <% end %>
        </div>

        <%# Right: results %>
        <div>
          <h2 class="cr-section-title">Results</h2>
          <div class="cr-results-placeholder">
            <% completed_matches = @past_matches.select(&:played?) %>
            <% if completed_matches.any? %>
              <% completed_matches.each do |match| %>
                <div class="cr-match-card" style="padding: 12px 16px;">
                  <div class="cr-match-row">
                    <div class="cr-match-date">
                      <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                      <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                    </div>
                    <div class="cr-match-info">
                      <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                      <div class="cr-match-result-row">
                        <span class="cr-result-badge <%= match.won? ? 'cr-result-badge-win' : 'cr-result-badge-loss' %>">
                          <%= match.result_label %>
                        </span>
                        <% if match.score_summary.present? %>
                          <span class="cr-result-score"><%= match.score_summary %></span>
                        <% end %>
                      </div>
                    </div>
                    <% if @is_captain %>
                      <%= link_to "Edit", edit_results_team_match_path(@team, match), class: "cr-enter-results-link" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <%# Show past matches without results (captain can enter them) %>
              <% unscored = @past_matches.reject(&:played?) %>
              <% if unscored.any? %>
                <% unscored.each do |match| %>
                  <div class="cr-match-card" style="padding: 12px 16px;">
                    <div class="cr-match-row">
                      <div class="cr-match-date">
                        <div class="cr-match-date-month"><%= match.match_date.strftime("%b").upcase %></div>
                        <div class="cr-match-date-day"><%= match.match_date.strftime("%-d") %></div>
                      </div>
                      <div class="cr-match-info">
                        <div class="cr-match-opponent">vs. <%= match.opponent %></div>
                        <span style="font-size: 0.8rem; color: var(--cr-text-light);">No result yet</span>
                      </div>
                      <% if @is_captain %>
                        <%= link_to "Enter Results", edit_results_team_match_path(@team, match), class: "cr-enter-results-link" %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div style="text-align: center; padding: 40px 20px; color: var(--cr-text-light);">
                  🎾 Season starts <%= @team.next_match ? @team.next_match.match_date.strftime("%B %-d") : "soon" %>!
                  <div style="margin-top: 8px; font-size: 0.85rem;">Results will appear here after each match.</div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# ── Tab 2: Roster ──────────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">Roster (<%= @player_count %> Players)</h2>
        <div class="cr-roster">
          <% @roster.each do |membership| %>
            <%= link_to player_path(membership.user), class: "cr-roster-row", style: "text-decoration: none; color: inherit;" do %>
              <div class="cr-roster-name <%= 'cr-roster-self' if membership.user_id == current_user.id %>">
                <%= membership.user.name %>
                <% if membership.user_id == current_user.id %>
                  (you)
                <% end %>
              </div>
              <% if membership.user.ntrp_rating.present? %>
                <div class="cr-roster-rating"><%= membership.user.ntrp_rating %></div>
              <% end %>
              <% if membership.captain? %>
                <div class="cr-roster-role cr-roster-role-captain">Captain</div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </section>
    </div>

    <%# ── Tab 3: Standings ───────────────────────────── %>
    <div data-team-tabs-target="panel" style="display: none;">
      <section class="cr-section">
        <h2 class="cr-section-title">Standings</h2>

        <%# Team's own record %>
        <div class="cr-standings-own">
          <div class="cr-standings-own-name"><%= @team.name %></div>
          <div class="cr-standings-own-record">
            <span class="cr-standings-wins"><%= @wins %>W</span>
            <span class="cr-standings-losses"><%= @losses %>L</span>
            <% total = @wins + @losses %>
            <% if total > 0 %>
              <span class="cr-standings-pct"><%= sprintf("%.0f", (@wins.to_f / total * 100)) %>%</span>
            <% end %>
          </div>
        </div>

        <%# Division opponents %>
        <% if @division_opponents.present? %>
          <h3 class="cr-section-subtitle" style="margin-top: 20px;">Division</h3>
          <div class="cr-standings-table">
            <div class="cr-standings-header">
              <span class="cr-standings-team-col">Team</span>
            </div>
            <% @division_opponents.each do |opp| %>
              <div class="cr-standings-row">
                <span class="cr-standings-team-col"><%= opp %></span>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @wins == 0 && @losses == 0 %>
          <div style="text-align: center; padding: 20px; color: var(--cr-text-light); font-size: 0.85rem;">
            🏆 Standings will update as the season progresses.
          </div>
        <% end %>
      </section>
    </div>
  </div>

</div>
