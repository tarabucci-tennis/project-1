<% content_for :title, "Create a Team · Court Report" %>

<div class="cr-page" style="max-width: 500px; margin: 0 auto; padding: 32px 24px;">
  <h1 class="cr-page-title" style="margin-bottom: 8px;">Create a Team</h1>
  <p style="color: var(--cr-text-muted); font-size: 0.9rem; margin-bottom: 24px;">
    You'll be the captain. Add players later from the Captain tab.
  </p>

  <%= form_with url: create_team_path, method: :post, local: true do |f| %>
    <div class="cr-field">
      <%= f.label :name, "Team Name" %>
      <%= f.text_field :name, placeholder: "e.g. Kiss My Ace", required: true,
          style: "width: 100%; padding: 12px 16px; border: 1px solid var(--cr-border); border-radius: 8px; font-size: 1rem;" %>
    </div>

    <div class="cr-field">
      <%= f.label :league_category, "League" %>
      <%= f.select :league_category, [["USTA", "USTA"], ["Inter-Club", "Inter-Club"], ["Local League (Del-Tri, etc.)", "Local"]],
          {}, style: "width: 100%; padding: 12px 16px; border: 1px solid var(--cr-border); border-radius: 8px; font-size: 1rem; background: var(--cr-white);" %>
    </div>

    <div class="cr-field">
      <%= f.label :team_type, "Division / Type (optional)" %>
      <%= f.text_field :team_type, placeholder: "e.g. Adult 40+, Adult 18+",
          style: "width: 100%; padding: 12px 16px; border: 1px solid var(--cr-border); border-radius: 8px; font-size: 1rem;" %>
    </div>

    <div class="cr-field">
      <%= f.label :season_name, "Season (optional)" %>
      <%= f.text_field :season_name, placeholder: "e.g. Spring 2026",
          style: "width: 100%; padding: 12px 16px; border: 1px solid var(--cr-border); border-radius: 8px; font-size: 1rem;" %>
    </div>

    <div style="margin-top: 24px;">
      <%= f.submit "Create Team", class: "cr-btn cr-btn-gold", style: "width: 100%; padding: 14px; font-size: 1rem;" %>
    </div>
  <% end %>
</div>
