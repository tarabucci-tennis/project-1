<% content_for(:title) { "Manage #{@team.name}" } %>

<p style="margin-bottom:16px;"><a href="<%= team_path(@team) %>" style="color:var(--accent);text-decoration:none;font-size:.85rem;">&larr; Back to <%= @team.name %></a></p>

<div class="cr-hero cr-hero-navy">
  <div class="cr-hero-grid"></div><div class="cr-hero-glow"></div>
  <div class="cr-hero-content">
    <div class="cr-hero-tag">Manage Team</div>
    <div class="cr-hero-title"><%= @team.name %></div>
  </div>
</div>

<!-- Edit Team Details -->
<div class="cr-section">
  <div class="cr-section-head"><div class="cr-section-title">Team Details</div><div class="cr-section-line"></div></div>
  <div class="cr-form">
    <%= form_with model: @team, url: team_path(@team), method: :patch do |f| %>
      <div class="cr-field-row">
        <div class="cr-field"><%= f.label :name %><%= f.text_field :name %></div>
        <div class="cr-field"><%= f.label :league %><%= f.select :league, Team::LEAGUES.map { |l| [l, l] }, { include_blank: "Select..." } %></div>
      </div>
      <div class="cr-field-row">
        <div class="cr-field"><%= f.label :team_type, "Division / Type" %><%= f.text_field :team_type %></div>
        <div class="cr-field"><%= f.label :rating %><%= f.select :rating, [3.0, 3.5, 4.0, 4.5, 5.0].map { |r| [r.to_s, r] }, { include_blank: "Select..." } %></div>
      </div>
      <div class="cr-field"><%= f.label :home_court %><%= f.text_field :home_court %></div>
      <div class="cr-field"><%= f.submit "Save Changes", class: "cr-btn" %></div>
    <% end %>
  </div>
</div>

<!-- Join Link -->
<div class="cr-section">
  <div class="cr-section-head"><div class="cr-section-title">Invite Players</div><div class="cr-section-line"></div></div>

  <p style="color:var(--sub);font-size:.85rem;margin-bottom:12px;">Share this link with your players — they'll sign up and be automatically added to the team:</p>
  <div class="cr-join-box">
    <div class="cr-join-url" id="joinUrl"><%= request.base_url %>/join/<%= @team.join_code %></div>
    <button class="cr-join-copy" onclick="navigator.clipboard.writeText(document.getElementById('joinUrl').textContent);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)">Copy</button>
  </div>

  <p style="color:var(--sub);font-size:.85rem;margin:20px 0 12px;">Or add players manually:</p>
  <%= form_with url: team_path(@team), method: :patch, local: true do |f| %>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <input type="text" name="add_player_name" placeholder="Player name" style="flex:1;min-width:150px;padding:10px;border:1px solid var(--border);border-radius:8px;">
      <input type="email" name="add_player_email" placeholder="Email (optional)" style="flex:1;min-width:150px;padding:10px;border:1px solid var(--border);border-radius:8px;">
      <button type="submit" name="add_player" value="1" class="cr-btn-sm cr-btn">+ Add Player</button>
    </div>
  <% end %>
</div>

<!-- Current Roster -->
<div class="cr-section">
  <div class="cr-section-head"><div class="cr-section-title">Current Roster (<%= @team.team_players.count %>)</div><div class="cr-section-line"></div></div>
  <div class="cr-card" style="padding:0;overflow:hidden;">
    <% @team.team_players.ordered.each do |player| %>
      <div style="display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid var(--border);">
        <div class="cr-avatar cr-avatar-blue" style="width:36px;height:36px;font-size:.8rem;">
          <%= player.player_name.split.map(&:first).join.upcase[0..1] %>
        </div>
        <div style="flex:1;">
          <span style="font-weight:600;"><%= player.player_name %></span>
          <% if player.user&.email %><span style="color:var(--sub);font-size:.78rem;margin-left:8px;"><%= player.user.email %></span><% end %>
        </div>
        <span style="font-size:.75rem;color:var(--sub);"><%= player.role %></span>
      </div>
    <% end %>
  </div>
</div>
