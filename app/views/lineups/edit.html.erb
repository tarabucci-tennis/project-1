<% content_for :title, "Set Lineup · #{@team.name} · Court Report" %>

<div class="cr-page">
  <%= link_to "← #{@team.name}", team_path(@team), class: "cr-back-link" %>

  <h1 class="cr-page-title">Set Lineup</h1>

  <div class="cr-result-match-info" style="margin-bottom: 24px;">
    <div class="cr-match-date">
      <div class="cr-match-date-month"><%= @match.match_date.strftime("%b").upcase %></div>
      <div class="cr-match-date-day"><%= @match.match_date.strftime("%-d") %></div>
    </div>
    <div class="cr-match-info">
      <div class="cr-match-opponent">vs. <%= @match.opponent %></div>
      <div class="cr-match-location">
        <%= @match.location %>
        <% if @match.match_time.present? %>
          · <%= @match.match_time %>
        <% end %>
      </div>
    </div>
    <% counts = @match.availability_counts %>
    <div style="text-align: right; font-size: 0.8rem; color: var(--cr-text-muted);">
      <span style="color: var(--cr-green); font-weight: 700;"><%= counts[:in] %> In</span> ·
      <span style="color: var(--cr-red); font-weight: 700;"><%= counts[:out] %> Out</span> ·
      <span><%= counts[:no_response] %> ?</span>
    </div>
  </div>

  <p class="cr-lineup-help" style="font-size: 0.85rem; color: var(--cr-text-muted); margin-bottom: 16px; padding: 12px 14px; background: rgba(201, 162, 74, 0.08); border-left: 3px solid var(--cr-gold); border-radius: 6px;">
    Pick a player for each line. Leave <strong>Already confirmed</strong> checked if you've already gotten a yes via text or in person — those players won't get an email asking them to confirm again. Uncheck it only if you want the app to email the player and ask.
  </p>

  <%= form_tag team_match_lineup_path(@team, @match), method: :patch do %>

    <div class="cr-lineup-grid">
      <%# Iterate over the team's lineup_slot_plan so USTA teams get
          1S + 4×2D while Inter-Club and Del-Tri teams get 6×2D. %>
      <% @team.lineup_slot_plan.each do |(line_type, position), _slot_count| %>
        <% line_label = line_type == "singles" ? "#{position}S — Singles" : "#{position}D — Doubles #{position}" %>
        <div class="cr-lineup-line-card">
          <div class="cr-lineup-line-label"><%= line_label %></div>
          <% slots_for_line = @slots.select { |s| s.line_type == line_type && s.position == position } %>
          <% slots_for_line.each_with_index do |slot, i| %>
            <div class="cr-lineup-slot-row">
              <select name="slots[<%= slot.id %>][user_id]" class="cr-select" style="max-width: 100%;">
                <% if line_type == "singles" %>
                  <option value="">-- Select player --</option>
                <% else %>
                  <option value="">-- Select player <%= i + 1 %> --</option>
                <% end %>
                <% @members.each do |m| %>
                  <option value="<%= m.id %>" <%= "selected" if slot.user_id == m.id %>><%= m.name %></option>
                <% end %>
              </select>
              <label class="cr-lineup-confirmed-toggle">
                <input type="hidden" name="slots[<%= slot.id %>][confirmed]" value="0">
                <input type="checkbox" name="slots[<%= slot.id %>][confirmed]" value="1" <%= "checked" unless slot.declined? %>>
                <span>Already confirmed</span>
              </label>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="cr-form-actions" style="margin-top: 24px;">
      <%= button_tag "Save Draft", type: :submit, name: "publish", value: "false", class: "cr-btn cr-btn-outline" %>
      <%= button_tag "Send to Team", type: :submit, name: "publish", value: "true", class: "cr-btn cr-btn-gold" %>
      <%= link_to "Cancel", team_path(@team), class: "cr-btn cr-btn-outline" %>
    </div>
  <% end %>
</div>
