<% content_for :title, "#{@team.name} · Team Results" %>

<div class="team-page">

  <%# ── Back link ── %>
  <div class="team-back">
    <%= link_to "← Back to Profile", profile_path, class: "back-link" %>
  </div>

  <%# ── Team header ── %>
  <div class="team-header">
    <div class="team-identity">
      <h1><%= @team.name %></h1>
      <div class="profile-meta">
        <span class="meta-chip"><%= @team.team_type %></span>
        <span class="meta-chip"><%= @team.section %></span>
        <span class="meta-chip"><%= @team.gender %></span>
        <% if @team.start_date.present? %>
          <span class="meta-chip">Started <%= @team.start_date.strftime("%-m/%-d/%Y") %></span>
        <% end %>
      </div>
    </div>

    <div class="team-stats-cards">
      <% if @team.rating.present? %>
        <div class="team-stat-card">
          <div class="team-stat-label">Team Rating</div>
          <div class="team-stat-value"><%= @team.rating %></div>
        </div>
      <% end %>

      <div class="team-stat-card">
        <div class="team-stat-label">Record</div>
        <div class="team-stat-value">
          <span class="td-win"><%= @record[:wins] %>W</span>
          <span class="record-dash">–</span>
          <span class="td-loss"><%= @record[:losses] %>L</span>
        </div>
      </div>

      <% if @matches.any? %>
        <div class="team-stat-card">
          <div class="team-stat-label">Win %</div>
          <div class="team-stat-value">
            <% total = @record[:wins] + @record[:losses] %>
            <%= total > 0 ? "#{(@record[:wins].to_f / total * 100).round(0)}%" : "—" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Match Results ── %>
  <section class="profile-section">
    <h2 class="section-title">Match Results</h2>

    <% if @matches.any? %>
      <div class="profile-table-wrap">
        <table class="profile-table matches-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Opponent Team</th>
              <th>Opponent Players</th>
              <th>Partner</th>
              <th>Location</th>
              <th>Ct</th>
              <th>Score</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody>
            <% @matches.each do |match| %>
              <tr>
                <td class="td-muted"><%= match.match_date.strftime("%-m/%-d/%Y") %></td>
                <td><%= match.match_type %></td>
                <td class="td-primary"><%= match.opponent_team %></td>
                <td><%= match.opponent_players %></td>
                <td><%= match.partner %></td>
                <td><%= match.location %></td>
                <td class="td-muted"><%= match.court_number %></td>
                <td class="td-primary"><%= match.score %></td>
                <td>
                  <span class="result-badge result-<%= match.result&.downcase %>">
                    <%= match.result %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="profile-empty">
        <p>No match results recorded yet.</p>
      </div>
    <% end %>
  </section>

</div>
