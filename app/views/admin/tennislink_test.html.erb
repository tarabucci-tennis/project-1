<% content_for :title, "TennisLink fetch test · Court Report admin" %>

<div style="max-width: 960px; margin: 0 auto; padding: 24px 16px;">
  <h1 style="margin-top: 0;">TennisLink fetch test</h1>
  <p style="color: #555;">
    Admin-only POC. Server-side fetches a public TennisLink IndividualPlayerRecord page
    and shows the raw response so we can see whether the droplet can reach it.
    No DB writes, no parsing.
  </p>

  <%= form_with url: admin_tennislink_test_path, method: :get, local: true do %>
    <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: end; margin-bottom: 16px;">
      <div class="cr-field" style="flex: 1 1 240px;">
        <label for="person_id">PersonID</label>
        <input type="text" name="person_id" id="person_id" value="<%= @person_id %>" placeholder="e.g. 12345678" />
      </div>
      <div class="cr-field" style="flex: 0 0 120px;">
        <label for="year">Year</label>
        <input type="text" name="year" id="year" value="<%= @year %>" />
      </div>
      <div>
        <button type="submit" class="cr-btn">Fetch</button>
      </div>
    </div>
  <% end %>

  <% if @person_id.blank? %>
    <p style="color: #666;">Enter a PersonID above to fetch. You can also pass <code>?person_id=X&amp;year=Y</code> in the URL.</p>
  <% else %>
    <div style="background: #f7f8fa; border: 1px solid #ddd; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; font-family: monospace; font-size: 13px;">
      <div><strong>URL:</strong> <a href="<%= @fetched_url %>" target="_blank" rel="noopener"><%= @fetched_url %></a></div>
      <div><strong>Elapsed:</strong> <%= @elapsed_ms %>ms</div>
      <div>
        <strong>Status:</strong>
        <% if @error %>
          <span style="color: #b00020; font-weight: bold;">ERROR — <%= @error %></span>
        <% elsif @status_code == 200 %>
          <span style="color: #0a7a2e; font-weight: bold;"><%= @status_code %> OK</span>
        <% elsif @status_code %>
          <span style="color: #b00020; font-weight: bold;">HTTP <%= @status_code %></span>
        <% end %>
      </div>
      <% if @body %>
        <div><strong>Body length:</strong> <%= @body.bytesize %> bytes</div>
      <% end %>
    </div>

    <% if @error || (@status_code && @status_code != 200) %>
      <div style="background: #fff0f0; border: 2px solid #b00020; color: #b00020; padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-weight: bold;">
        <% if @error&.start_with?("TIMEOUT") %>
          TIMEOUT — the droplet could not reach TennisLink within <%= AdminController::FETCH_TIMEOUT_SECONDS %>s.
        <% elsif @status_code == 503 %>
          HTTP 503 — TennisLink refused the request. Likely bot detection / WAF.
        <% elsif @status_code == 403 %>
          HTTP 403 — TennisLink denied access. Likely bot detection or a cookie/session requirement.
        <% elsif @error %>
          Fetch failed: <%= @error %>
        <% else %>
          Non-200 response: <%= @status_code %>.
        <% end %>
      </div>
    <% end %>

    <% if @body.present? %>
      <h2 style="margin-top: 24px;">Raw response body</h2>
      <pre style="background: #1a1a1a; color: #e0e0e0; padding: 12px; border-radius: 6px; overflow: auto; max-height: 600px; font-size: 12px; white-space: pre-wrap; word-break: break-word;"><%= @body %></pre>
    <% end %>
  <% end %>
</div>
