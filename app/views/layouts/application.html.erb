<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tara's Tennis Club" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tara's Tennis Club">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <% if current_user&.admin? %>
        <a href="/" class="navbar-brand">Tara's Sandbox</a>
      <% else %>
        <span class="navbar-brand navbar-brand-static">Tara's Sandbox</span>
      <% end %>
      <div class="navbar-center">
        <%= link_to "Tennis", tennis_path, class: "nav-link" %>
        <%= link_to "Teams", teams_path, class: "nav-link" %>
        <% if current_user&.admin? %>
          <span class="nav-link nav-link-coming-soon">Project 2</span>
        <% end %>
      </div>
      <div class="navbar-right">
        <% if current_user %>
          <% if current_user.admin? %>
            <%= link_to "Players", users_path, class: "nav-link" %>
          <% end %>
          <%= link_to settings_path, class: "nav-notif-link" do %>
            <span class="nav-notif-icon">&#x2699;&#xFE0F;</span>
            <% if current_user.unread_notifications_count > 0 %>
              <span class="nav-notif-badge"><%= current_user.unread_notifications_count %></span>
            <% end %>
          <% end %>
          <%= link_to current_user.name, profile_path, class: "nav-user" %>
          <%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-sm" %>
        <% else %>
          <%= link_to "Sign In", login_path, class: "btn btn-sm" %>
        <% end %>
      </div>
    </nav>

    <% if notice %>
      <div class="flash flash-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash-alert"><%= alert %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
