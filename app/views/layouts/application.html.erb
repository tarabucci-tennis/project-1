<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Court Report" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Court Report">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png?v=3" type="image/png">
    <link rel="icon" href="/icon.svg?v=3" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png?v=3">

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="cr-header">
      <div class="cr-header-inner">
        <%= link_to (current_user ? teams_path : root_path), class: "cr-brand" do %>
          <span class="cr-brand-ball"><span class="cr-brand-ball-inner">🎾</span></span>
          <span class="cr-brand-text">COURT <span class="cr-brand-gold">REPORT</span></span>
        <% end %>

        <div class="cr-header-right">
          <% if current_user %>
            <%= link_to "My Teams", teams_path, class: "cr-header-pill cr-header-my-teams" %>
            <%= link_to current_user.name, profile_path, class: "cr-header-user" %>
            <%= button_to "Sign Out", session_path, method: :delete, class: "cr-header-pill cr-header-signout", form: { style: "display:inline-flex; margin:0;" } %>
          <% elsif !%w[sessions registrations].include?(controller_name) %>
            <%= link_to "Sign In", login_path, class: "cr-header-pill" %>
            <%= link_to "Sign Up", signup_path, class: "cr-header-pill cr-header-signup" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="cr-flash cr-flash-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="cr-flash cr-flash-alert"><%= alert %></div>
    <% end %>

    <main class="cr-main">
      <%= yield %>
    </main>

    <%# Tiny inline scripts: password eye toggle + join-link copy button %>
    <script>
      function togglePassword(btn) {
        var wrapper = btn.parentElement;
        var field = wrapper.querySelector('input[type="password"], input[type="text"]');
        if (!field) return;
        if (field.type === 'password') {
          field.type = 'text';
          btn.textContent = '🙈';
          btn.setAttribute('aria-label', 'Hide password');
        } else {
          field.type = 'password';
          btn.textContent = '👁';
          btn.setAttribute('aria-label', 'Show password');
        }
      }

      function crCopyJoinLink(btn) {
        var targetId = btn.getAttribute('data-target');
        var field = document.getElementById(targetId);
        if (!field) return;
        var value = field.value;
        var original = btn.textContent;
        var flash = function () {
          btn.textContent = 'Copied!';
          setTimeout(function () { btn.textContent = original; }, 1500);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(value).then(flash, function () {
            field.select();
            try { document.execCommand('copy'); flash(); } catch (e) {}
          });
        } else {
          field.select();
          try { document.execCommand('copy'); flash(); } catch (e) {}
        }
      }
    </script>

    <% if current_user %>
      <% in_team_context = request.path.match?(%r{\A/teams/\d+}) %>
      <nav class="cr-bottom-nav" aria-label="Primary">
        <div class="cr-bottom-nav-inner">
      <% if in_team_context %>
          <%= link_to teams_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'teams' && action_name == 'index'}" do %>
            <span class="cr-bnav-icon">🏠</span>
            <span class="cr-bnav-label">Home</span>
          <% end %>
          <%= link_to lineups_dashboard_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'lineups'}" do %>
            <span class="cr-bnav-icon">📝</span>
            <span class="cr-bnav-label">Lineups</span>
          <% end %>
          <a href="/teams" data-bnav-tab="standings" class="cr-bnav-btn">
            <span class="cr-bnav-icon">🏆</span>
            <span class="cr-bnav-label">Standings</span>
          </a>
          <a href="/teams" data-bnav-tab="roster" class="cr-bnav-btn">
            <span class="cr-bnav-icon">👥</span>
            <span class="cr-bnav-label">Roster</span>
          </a>
          <a href="https://chat.whatsapp.com/" target="_blank" rel="noopener" class="cr-bnav-btn">
            <span class="cr-bnav-icon">💬</span>
            <span class="cr-bnav-label">WhatsApp</span>
          </a>
      <% else %>
          <%= link_to teams_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'teams' && action_name == 'index'}" do %>
            <span class="cr-bnav-icon">🏠</span>
            <span class="cr-bnav-label">Home</span>
          <% end %>
          <%= link_to lineups_dashboard_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'lineups'}" do %>
            <span class="cr-bnav-icon">📝</span>
            <span class="cr-bnav-label">Lineups</span>
          <% end %>
          <%= link_to find_team_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'teams' && action_name == 'search'}" do %>
            <span class="cr-bnav-icon">🔍</span>
            <span class="cr-bnav-label">Find Team</span>
          <% end %>
          <%= link_to profile_path, class: "cr-bnav-btn #{'cr-bnav-active' if controller_name == 'profiles' && action_name == 'show'}" do %>
            <span class="cr-bnav-icon">👤</span>
            <span class="cr-bnav-label">Profile</span>
          <% end %>
          <a href="https://chat.whatsapp.com/" target="_blank" rel="noopener" class="cr-bnav-btn">
            <span class="cr-bnav-icon">💬</span>
            <span class="cr-bnav-label">WhatsApp</span>
          </a>
      <% end %>
        </div>
      </nav>

      <%# Smart bottom-nav: if we're on a team show page (/teams/:id),
          rewrite the Roster and Standings buttons to deep-link to the
          current team with ?tab=roster / ?tab=standings. The
          team_tabs_controller reads the ?tab= param on connect and
          switches to that sub-tab. When not on a team page, the buttons
          just fall back to /teams. %>
      <script>
        (function () {
          var teamMatch = window.location.pathname.match(/^\/teams\/(\d+)/);
          if (!teamMatch) return;
          var teamId = teamMatch[1];
          document.querySelectorAll('[data-bnav-tab]').forEach(function (btn) {
            var tab = btn.getAttribute('data-bnav-tab');
            btn.setAttribute('href', '/teams/' + teamId + '?tab=' + tab);
          });
        })();
      </script>
    <% end %>
  </body>
</html>
