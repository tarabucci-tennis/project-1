<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Court Report" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Court Report">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="cr-header">
      <div class="cr-header-inner">
        <%= link_to (current_user ? teams_path : root_path), class: "cr-brand" do %>
          <span class="cr-brand-ball">🎾</span>
          <span class="cr-brand-text">COURT <span class="cr-brand-gold">REPORT</span></span>
        <% end %>

        <div class="cr-header-right">
          <% if current_user %>
            <%= link_to "My Teams", teams_path, class: "cr-header-pill" %>
            <%= link_to current_user.name, profile_path, class: "cr-header-user" %>
            <%= button_to "Sign Out", session_path, method: :delete, class: "cr-header-pill cr-header-signout", form: { style: "display:inline" } %>
          <% else %>
            <%= link_to "Sign In", login_path, class: "cr-header-pill" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="cr-flash cr-flash-notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="cr-flash cr-flash-alert"><%= alert %></div>
    <% end %>

    <main class="cr-main">
      <%= yield %>
    </main>
  </body>
</html>
