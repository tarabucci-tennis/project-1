<% content_for :title, "#{@team.name} vs. #{@match.opponent} · Court Report" %>

<div class="cr-page" style="max-width: 700px; margin: 0 auto; padding: 24px;">

  <%= link_to "← #{@team.name}", team_path(@team), class: "cr-back-link" %>

  <%# ── Match header bar ── %>
  <div class="cr-lineup-match-header">
    <div style="display: flex; align-items: center; gap: 12px; flex: 1;">
      <span style="font-weight: 800; font-size: 1.05rem;">
        <%= @match.match_date.strftime("%b %-d").upcase %>
        <% if @match.match_time.present? %>
          <span style="font-weight: 400; color: var(--cr-text-muted);"> - <%= @match.match_time.gsub(" ", "").downcase %></span>
        <% end %>
      </span>
      <% if @match.notes&.include?("Home") %>
        <span class="cr-my-week-badge-home">Home</span>
      <% elsif @match.notes&.include?("Away") %>
        <span class="cr-my-week-badge-away">Away</span>
      <% end %>
      <span style="color: var(--cr-text-muted);">vs</span>
      <span style="font-weight: 700;"><%= @match.opponent %></span>
    </div>
    <div style="display: flex; gap: 8px; align-items: center;">
      <a href="<%= google_calendar_url(@match) %>" target="_blank" rel="noopener" class="cr-cal-btn" title="Add to Google Calendar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </a>
      <% if @is_captain %>
        <%= link_to "Set Lineup", edit_team_match_lineup_path(@team, @match), class: "cr-btn cr-btn-gold", style: "padding: 6px 14px; font-size: 0.8rem;" %>
      <% end %>
    </div>
  </div>

  <%# ── Lineup table ── %>
  <% if @lineup&.published? && @slots&.any? %>
    <div class="cr-lineup-table">
      <div class="cr-lineup-table-header">
        <span class="cr-lineup-col-time">Time</span>
        <span class="cr-lineup-col-line">Line</span>
        <span class="cr-lineup-col-player">Player</span>
        <span class="cr-lineup-col-status"></span>
      </div>

      <% grouped = @slots.group_by { |s| "#{s.position}#{s.line_type == 'singles' ? 'S' : 'D'}" } %>
      <% grouped.each do |line_label, slots| %>
        <div class="cr-lineup-line-group">
          <% slots.each_with_index do |slot, idx| %>
            <div class="cr-lineup-table-row <%= 'cr-lineup-row-you' if slot.user_id == current_user.id %>">
              <span class="cr-lineup-col-time">
                <% if idx == 0 %>
                  <strong><%= @match.match_time&.gsub(" ", "")&.downcase || "TBD" %></strong>
                <% end %>
              </span>
              <span class="cr-lineup-col-line">
                <% if idx == 0 %>
                  <strong><%= line_label %></strong>
                <% end %>
              </span>
              <span class="cr-lineup-col-player">
                <%= slot.user.name %>
              </span>
              <span class="cr-lineup-col-status">
                <% if slot.confirmed? %>
                  <span class="cr-lineup-status-confirmed">✓ Confirmed</span>
                <% elsif slot.declined? %>
                  <span class="cr-lineup-status-declined">✗ Declined</span>
                <% else %>
                  <span class="cr-lineup-status-pending">Pending</span>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Confirm/decline prompt for current user %>
    <% my_slot = @lineup.slot_for(current_user) %>
    <% if my_slot&.pending? %>
      <div class="cr-lineup-confirm-prompt">
        <span>You're on <strong><%= my_slot.line_label %></strong> — can you play?</span>
        <div style="display: flex; gap: 8px;">
          <%= link_to "✓ Confirm", confirm_team_match_lineup_path(@team, @match, status: "confirmed"), class: "cr-btn cr-btn-gold", style: "padding: 8px 18px; font-size: 0.85rem;" %>
          <%= link_to "✗ Can't Play", confirm_team_match_lineup_path(@team, @match, status: "declined"), class: "cr-btn cr-btn-outline", style: "padding: 8px 18px; font-size: 0.85rem;" %>
        </div>
      </div>
    <% end %>

  <% else %>
    <div style="text-align: center; padding: 48px 20px; background: var(--cr-white); border: 1px solid var(--cr-border); border-radius: 10px; color: var(--cr-text-light); margin-top: 4px;">
      <span style="font-size: 0.85rem; padding: 6px 14px; border: 1px solid var(--cr-border); border-radius: 6px; display: inline-block; color: var(--cr-text-muted);">No lineup posted</span>
      <% if @is_captain %>
        <div style="margin-top: 14px;">
          <%= link_to "Set Lineup", edit_team_match_lineup_path(@team, @match), class: "cr-btn cr-btn-gold", style: "padding: 8px 20px; font-size: 0.85rem;" %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
