<% content_for :title, "#{@team.name} vs. #{@match.opponent} · Court Report" %>

<div class="cr-page" style="max-width: 700px; margin: 0 auto; padding: 24px;">

  <%= link_to "← #{@team.name}", team_path(@team), class: "cr-back-link" %>

  <%# ── Match header ── %>
  <div class="cr-match-detail-header">
    <div class="cr-match-detail-date">
      <div class="cr-match-date-month"><%= @match.match_date.strftime("%a %b").upcase %></div>
      <div style="font-size: 2.2rem; font-weight: 900; color: var(--cr-text); line-height: 1;"><%= @match.match_date.strftime("%-d") %></div>
    </div>
    <div style="flex: 1;">
      <div style="font-size: 0.6rem; font-weight: 700; color: var(--cr-gold); letter-spacing: 1px; text-transform: uppercase;">
        <%= @team.league_category == "Local" ? "DEL-TRI" : @team.league_category %>
      </div>
      <h1 style="font-size: 1.4rem; font-weight: 800; margin: 2px 0;"><%= @team.name %></h1>
      <div style="font-size: 1rem; color: var(--cr-text-muted);">vs. <%= @match.opponent %></div>
      <div style="font-size: 0.85rem; color: var(--cr-text-light); margin-top: 4px;">
        <% if @match.match_time.present? %>
          <strong><%= @match.match_time %></strong> ·
        <% end %>
        <%= @match.location %>
        <% if @match.notes&.include?("Home") %>
          <span class="cr-my-week-badge-home" style="margin-left: 6px;">Home</span>
        <% elsif @match.notes&.include?("Away") %>
          <span class="cr-my-week-badge-away" style="margin-left: 6px;">Away</span>
        <% end %>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 6px; align-items: flex-end;">
      <a href="<%= google_calendar_url(@match) %>" target="_blank" rel="noopener" class="cr-cal-btn" title="Add to Google Calendar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </a>
      <% if @is_captain %>
        <%= link_to "Set Lineup", edit_team_match_lineup_path(@team, @match), class: "cr-btn cr-btn-gold", style: "padding: 6px 14px; font-size: 0.8rem;" %>
      <% end %>
    </div>
  </div>

  <%# ── Availability section ── %>
  <div style="margin: 20px 0; padding: 14px 18px; background: var(--cr-white); border: 1px solid var(--cr-border); border-radius: 10px;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div style="font-size: 0.75rem; font-weight: 700; color: var(--cr-text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Your Availability</div>
      <div style="display: flex; gap: 8px;">
        <% avail_status = @my_availability&.status %>
        <%= button_to match_availability_path(@match, status: "in"),
            class: "cr-avail-btn cr-avail-in #{avail_status == 'in' ? 'avail-btn-active' : ''}",
            style: "padding: 6px 14px; font-size: 0.8rem;" do %>
          I'm In
        <% end %>
        <%= button_to match_availability_path(@match, status: "out"),
            class: "cr-avail-btn cr-avail-out #{avail_status == 'out' ? 'avail-btn-active' : ''}",
            style: "padding: 6px 14px; font-size: 0.8rem;" do %>
          I'm Out
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Lineup table ── %>
  <div style="margin-top: 24px;">
    <% if @lineup&.published? && @slots&.any? %>
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
        <h2 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--cr-text-muted);">Lineup</h2>
        <span style="font-size: 0.7rem; font-weight: 600; color: var(--cr-green); text-transform: uppercase; letter-spacing: 0.5px;">Posted</span>
      </div>

      <div class="cr-lineup-table">
        <div class="cr-lineup-table-header">
          <span class="cr-lineup-col-time">Time</span>
          <span class="cr-lineup-col-line">Line</span>
          <span class="cr-lineup-col-player">Player</span>
          <span class="cr-lineup-col-status">Status</span>
        </div>

        <% grouped = @slots.group_by { |s| "#{s.position}#{s.line_type == 'singles' ? 'S' : 'D'}" } %>
        <% grouped.each do |line_label, slots| %>
          <% slots.each_with_index do |slot, idx| %>
            <div class="cr-lineup-table-row <%= 'cr-lineup-row-you' if slot.user_id == current_user.id %>">
              <span class="cr-lineup-col-time">
                <% if idx == 0 %>
                  <strong><%= @match.match_time || "TBD" %></strong>
                <% end %>
              </span>
              <span class="cr-lineup-col-line">
                <% if idx == 0 %>
                  <strong><%= line_label %></strong>
                <% end %>
              </span>
              <span class="cr-lineup-col-player">
                <%= slot.user.name %>
                <% if slot.user_id == current_user.id %>
                  <span style="color: var(--cr-gold); font-size: 0.75rem;">(you)</span>
                <% end %>
              </span>
              <span class="cr-lineup-col-status">
                <% if slot.confirmed? %>
                  <span class="cr-lineup-status-confirmed">✓ Confirmed</span>
                <% elsif slot.declined? %>
                  <span class="cr-lineup-status-declined">✗ Declined</span>
                <% else %>
                  <span class="cr-lineup-status-pending">Pending</span>
                <% end %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Confirm/decline for current user %>
      <% my_slot = @lineup.slot_for(current_user) %>
      <% if my_slot&.pending? %>
        <div style="margin-top: 16px; padding: 14px 18px; background: #fef9ee; border: 1px solid #f0dca0; border-radius: 10px; display: flex; align-items: center; justify-content: space-between;">
          <span style="font-size: 0.9rem; font-weight: 600;">You're on <strong><%= my_slot.line_label %></strong> — can you play?</span>
          <div style="display: flex; gap: 8px;">
            <%= link_to "✓ Confirm", confirm_team_match_lineup_path(@team, @match, status: "confirmed"), class: "cr-btn cr-btn-gold", style: "padding: 8px 18px; font-size: 0.85rem;" %>
            <%= link_to "✗ Can't Play", confirm_team_match_lineup_path(@team, @match, status: "declined"), class: "cr-btn cr-btn-outline", style: "padding: 8px 18px; font-size: 0.85rem;" %>
          </div>
        </div>
      <% end %>

    <% else %>
      <div style="text-align: center; padding: 40px 20px; background: var(--cr-white); border: 1px solid var(--cr-border); border-radius: 10px; color: var(--cr-text-light);">
        <div style="font-size: 0.85rem; padding: 6px 14px; border: 1px solid var(--cr-border); border-radius: 6px; display: inline-block; color: var(--cr-text-muted);">No lineup posted</div>
        <% if @is_captain %>
          <div style="margin-top: 12px;">
            <%= link_to "Set Lineup", edit_team_match_lineup_path(@team, @match), class: "cr-btn cr-btn-gold", style: "padding: 8px 20px; font-size: 0.85rem;" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
