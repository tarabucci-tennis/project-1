<% content_for(:title) { "Sign In - Court Report" } %>

<div style="max-width:400px;margin:60px auto;padding:0 24px;">

  <div style="text-align:center;margin-bottom:40px;">
    <div style="font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:4px;color:var(--text);">Welcome Back</div>
  </div>

  <%= form_with url: session_path, method: :post do |f| %>
    <div style="margin-bottom:20px;">
      <label style="display:block;font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--sub);margin-bottom:6px;">Email Address</label>
      <%= f.email_field :email, placeholder: "you@example.com", autofocus: true, style: "width:100%;padding:14px 16px;background:#fff;border:1px solid var(--border);border-radius:10px;font-family:'Inter',sans-serif;font-size:.92rem;color:var(--text);outline:none;" %>
    </div>
    <div style="margin-bottom:24px;">
      <label style="display:block;font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--sub);margin-bottom:6px;">Password</label>
      <div style="position:relative;">
        <%= f.password_field :password, placeholder: "Your password", id: "login-password", style: "width:100%;padding:14px 16px;padding-right:44px;background:#fff;border:1px solid var(--border);border-radius:10px;font-family:'Inter',sans-serif;font-size:.92rem;color:var(--text);outline:none;" %>
        <button type="button" onclick="togglePassword('login-password', this)" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--sub);padding:0;" title="Show password">👁</button>
      </div>
    </div>
    <%= f.submit "Sign In", style: "width:100%;padding:14px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--navy);font-family:'Inter',sans-serif;font-size:.95rem;font-weight:700;border:none;border-radius:10px;cursor:pointer;letter-spacing:.3px;" %>
  <% end %>

  <div style="text-align:center;margin-top:28px;display:flex;flex-direction:column;gap:10px;">
    <a href="<%= signup_path %>" style="font-size:.82rem;color:var(--sub);text-decoration:none;">First time? <span style="color:var(--accent);font-weight:600;">Request your password</span></a>
    <a href="#" style="font-size:.82rem;color:var(--sub);text-decoration:none;">Forgot password? <span style="color:var(--accent);font-weight:600;">Retrieve it here</span></a>
  </div>

</div>

<script>
function togglePassword(fieldId, btn) {
  var field = document.getElementById(fieldId);
  if (field.type === "password") {
    field.type = "text";
    btn.textContent = "🙈";
    btn.title = "Hide password";
  } else {
    field.type = "password";
    btn.textContent = "👁";
    btn.title = "Show password";
  }
}
</script>
