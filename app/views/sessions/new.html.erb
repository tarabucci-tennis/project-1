<% content_for :title, "Sign In · Court Report" %>

<div class="cr-login-page">
  <div class="cr-login-card">
    <h1>Sign In</h1>
    <p class="cr-login-sub">Enter your email to continue</p>

    <%= form_with url: session_path, method: :post do |f| %>
      <div class="cr-field">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "you@example.com", autofocus: true %>
      </div>
      <%= f.submit "Sign In →" %>
    <% end %>
  </div>
</div>
