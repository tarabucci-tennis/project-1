<% content_for :title, "Sign In — Court Report" %>

<div class="cr-auth-page">
  <div class="cr-auth-card">
    <div class="cr-auth-logo">
      <span class="cr-auth-logo-ball">🎾</span>
    </div>
    <h1 class="cr-auth-title">Sign In</h1>
    <p class="cr-auth-sub">Welcome back to Court Report</p>

    <%= form_with url: session_path, method: :post do |f| %>
      <div class="cr-field">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, placeholder: "you@example.com", autofocus: true %>
      </div>
      <%= f.submit "Sign In →", class: "cr-auth-submit" %>
    <% end %>

    <p class="cr-auth-switch">
      New to Court Report?
      <%= link_to "Create an account", signup_path %>
    </p>
  </div>
</div>
